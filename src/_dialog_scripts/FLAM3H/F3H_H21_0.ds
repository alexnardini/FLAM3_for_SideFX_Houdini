            groupcollapsible {
                name    "f_iteraffinedo_#"
                label   "#: post affine"
                disablewhentab "{ vactive_# == 0 } { iw_# == 0 }"
                grouptag { "group_type" "collapsible" }
                parmtag { "sidefx::header_toggle" "dopost_#" }

                parm {
                    name    "dopost_#"
                    label   "post"
                    type    toggle
                    default { "0" }
                    help    "OFF by default.\\nEnable post affine."
                    parmtag { "script_callback_language" "python" }
                }
            }

            group {
                name    "f_iteraffine_#"
                label   "#: pre affine"

                groupsimple {
                    name    "f_iterpreaffinedata_#"
                    label   "PRE AFFINE"
                    disablewhentab "{ vactive_# == 0 } { iw_# == 0 }"
                    grouptag { "group_type" "simple" }

                    parm {
                        name    "scl_#"
                        label   "Scale"
                        type    float
                        default { "1" }
                        help    "Scale pre affine values (X and Y) by an amount, with a value of 1 (100% -> no scale) being the default.\\n\\nThe are two ways to use this parameter:\\n- Input a value into the numeric field. For example if you type: 1.2 it will scale the affine up by 20%.\\n- [LMB] into the numeric field and use the mouse wheel to increment the scale up and down.\\n\\nWhen using the mouse wheel:\\n- [mouse wheel] will scale the value by an increment of: +/- 0.1\\n- [SHIFT] + [mouse wheel] will scale the value by an increment of: +/- 0.01\\n- [CTRL] + [mouse wheel] will scale the value by an increment of: +/- 1\\n\\nAdditionally:\\nThe parameter's slider ranges are between 0.975 and 1.025 to allow for precise and very small value changes when dragged left or right.\\n\\nNOTE:\\nThis parameter can not be animated.\\nEvery time you either input a value, drag the slider or use the mouse wheel to increment the value, it will revert back to the default value of 1 (100% -> no scale)."
                        range   { 0.975 1.025 }
                        parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_iterator_utils(kwargs).prm_paste_sel_pre_affine()" }
                        parmtag { "script_action_help" "[LMB] to copy the values from the POST Affine into here, the PRE Affine. It will copy: X, Y, O and Rot. Additionally: [SHIFT+LMB] to copy only the X and Y values. [CTRL+LMB] to copy only the O value. [ALT+LMB] to copy only the Rotation angle value." }
                        parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_StarSwapRedCopyPasteAffineSVG.svg" }
                        parmtag { "script_callback" "hou.phm().flam3.flam3h_iterator_utils(kwargs).iterator_affine_scale()" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "x_#"
                        label   "X"
                        type    vector2
                        size    2
                        default { "1" "0" }
                        help    "pre: X.x, X.y ( A, D )"
                        range   { -1 1 }
                        parmtag { "script_callback" "" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "y_#"
                        label   "Y"
                        type    vector2
                        size    2
                        default { "0" "1" }
                        help    "pre: Y.x, Y.y ( B, E )"
                        range   { -1 1 }
                        parmtag { "script_callback" "" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "o_#"
                        label   "O"
                        type    vector2
                        size    2
                        default { "0" "0" }
                        help    "pre (offset): O.x, O.y ( C, F )"
                        range   { -1 1 }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "ang_#"
                        label   "Rot"
                        type    float
                        default { "0" }
                        help    "Rotate pre affine in angle degrees.\\nThe rotation will take the values of X, Y, O and apply a rotation (with O being the pivot).\\n\\nNote:\\nthe resulting affine coefficients are not updated in the UI but passed directly internally to the algorithm."
                        range   { -90 90 }
                        parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_iterator_utils(kwargs).reset_preaffine()" }
                        parmtag { "script_action_help" "[LMB] to reset all affine values. [SHIFT+LMB] to reset only the affine X and Y values. [CTRL+LMB] to reset only the affine O value. [ALT+LMB] to reset only the affine Rotation angle value." }
                        parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarWhiteKwargsSVG.svg" }
                        parmtag { "script_callback_language" "python" }
                    }
                }

            }

            group {
                name    "f_iteraffine_#_1"
                label   "#: post affine"

                groupsimple {
                    name    "f_iterpostaffinedata_#"
                    label   "POST AFFINE"
                    disablewhentab "{ dopost_# == 0 } { vactive_# == 0 } { iw_# == 0 }"
                    grouptag { "group_type" "simple" }

                    parm {
                        name    "pscl_#"
                        label   "Scale"
                        type    float
                        default { "1" }
                        help    "Scale post affine values (X and Y) by an amount, with a value of 1 (100% -> no scale) being the default.\\n\\nThe are two ways to use this parameter:\\n- Input a value into the numeric field. For example if you type: 1.2 it will scale the affine up by 20%.\\n- [LMB] into the numeric field and use the mouse wheel to increment the scale up and down.\\n\\nWhen using the mouse wheel:\\n- [mouse wheel] will scale the value by an increment of: +/- 0.1\\n- [SHIFT] + [mouse wheel] will scale the value by an increment of: +/- 0.01\\n- [CTRL] + [mouse wheel] will scale the value by an increment of: +/- 1\\n\\nAdditionally:\\nThe parameter's slider ranges are between 0.975 and 1.025 to allow for precise and very small value changes when dragged left or right.\\n\\nNOTE:\\nThis parameter can not be animated.\\nEvery time you either input a value, drag the slider or use the mouse wheel to increment the value, it will revert back to the default value of 1 (100% -> no scale)."
                        range   { 0.975 1.025 }
                        parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_iterator_utils(kwargs).prm_paste_sel_post_affine()" }
                        parmtag { "script_action_help" "[LMB] to copy the values from the PRE Affine into here, the POST Affine. It will copy: X, Y, O and Rot. Additionally: [SHIFT+LMB] to copy only the X and Y values. [CTRL+LMB] to copy only the O value. [ALT+LMB] to copy only the Rotation angle value." }
                        parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_StarSwapRedCopyPasteAffineSVG.svg" }
                        parmtag { "script_callback" "hou.phm().flam3.flam3h_iterator_utils(kwargs).iterator_post_affine_scale()" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "px_#"
                        label   "X"
                        type    vector2
                        size    2
                        default { "1" "0" }
                        help    "post: X.x, X.y ( A, D )"
                        range   { -1 1 }
                        parmtag { "script_callback" "" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "py_#"
                        label   "Y"
                        type    vector2
                        size    2
                        default { "0" "1" }
                        help    "post: Y.x, Y.y ( B, E )"
                        range   { -1 1 }
                        parmtag { "script_callback" "" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "po_#"
                        label   "O"
                        type    vector2
                        size    2
                        default { "0" "0" }
                        help    "post (offset): O.x, O.y ( C, F )"
                        range   { -1 1 }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "pang_#"
                        label   "Rot"
                        type    float
                        default { "0" }
                        help    "Rotate post affine in angle degrees.\\nThe rotation will take the values of X, Y, O and apply a rotation (with O being the pivot).\\n\\nNote:\\nthe resulting affine coefficients are not updated in the UI but passed directly internally to the algorithm."
                        range   { -90 90 }
                        parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_iterator_utils(kwargs).reset_postaffine()" }
                        parmtag { "script_action_help" "[LMB] to reset all affine values. [SHIFT+LMB] to reset only the affine X and Y values. [CTRL+LMB] to reset only the affine O value. [ALT+LMB] to reset only the affine Rotation angle value." }
                        parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarWhiteKwargsSVG.svg" }
                        parmtag { "script_callback_language" "python" }
                    }
                }

            }

            group {
                name    "f_iteraffine_#_2"
                label   "#: VARS"

                groupsimple {
                    name    "f_itervariablesdata_#"
                    label   "VARS PARAMETERS"
                    disablewhentab "{ vactive_# == 0 } { iw_# == 0 }"
                    grouptag { "group_type" "simple" }

                    parm {
                        name    "auger_#"
                        label   "f/s/s/w AUGER"
                        type    vector4
                        size    4
                        default { "1" "2" "1" "1" }
                        help    "\\nFREQUENCY, SCALE, SYMMETRY, WEIGHT"
                        hidewhen "{ p1type_# != 94 pre1type_# != 94 pre2type_# != 94 v1type_# != 94 v2type_# != 94 v3type_# != 94 v4type_# != 94 v5type_# != 94 }"
                        range   { 0 4 }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "bent2xy_#"
                        label   "xy BENT2"
                        type    vector2
                        size    2
                        default { "1.5" "0" }
                        help    "\\nX, Y"
                        hidewhen "{ p1type_# != 52 pre1type_# != 52 pre2type_# != 52 v1type_# != 52 v2type_# != 52 v3type_# != 52 v4type_# != 52 v5type_# != 52 }"
                        range   { 0 2 }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "bipolarshift_#"
                        label   "shift BIPOLAR"
                        type    float
                        default { "1" }
                        help    "\\nSHIFT"
                        hidewhen "{ p1type_# != 53 pre1type_# != 53 pre2type_# != 53 v1type_# != 53 v2type_# != 53 v3type_# != 53 v4type_# != 53 v5type_# != 53 }"
                        range   { 0 10 }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "blob_#"
                        label   "low/high/wave BLOB"
                        type    vector
                        size    3
                        default { "0.2" "1" "6" }
                        help    "\\nLOW, HIGH, WAVE"
                        hidewhen "{ pre1type_# != 30 pre2type_# != 30 p1type_# != 30 v1type_# != 30 v2type_# != 30 v3type_# != 30 v4type_# != 30 v5type_# != 30 }"
                        range   { -1 1 }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "bwraps_#"
                        label   "s/s/g BWRAPS"
                        type    vector
                        size    3
                        default { "0.5" "0" "1" }
                        help    "\\nSIZE, SPACE, GAIN"
                        hidewhen "{ p1type_# != 99 pre1type_# != 99 pre2type_# != 99 v1type_# != 99 v2type_# != 99 v3type_# != 99 v4type_# != 99 v5type_# != 99 }"
                        range   { 0 2 }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "bwrapstwist_#"
                        label   "in/out twist BWRAPS"
                        type    vector2
                        size    2
                        default { "3" "0" }
                        help    "\\nIN TWIST, OUT TWIST"
                        hidewhen "{ p1type_# != 99 pre1type_# != 99 pre2type_# != 99 v1type_# != 99 v2type_# != 99 v3type_# != 99 v4type_# != 99 v5type_# != 99 }"
                        range   { 0 2 }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "cellsize_#"
                        label   "size CELL"
                        type    float
                        default { "0.05" }
                        help    "\\nSIZE"
                        hidewhen "{ p1type_# != 56 pre1type_# != 56 pre2type_# != 56 v1type_# != 56 v2type_# != 56 v3type_# != 56 v4type_# != 56 v5type_# != 56 }"
                        range   { 0 1 }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "conic_#"
                        label   "ecc/holes CONIC"
                        type    vector2
                        size    2
                        default { "0.5" "0.5" }
                        help    "\\nECCENTRICITY, HOLES"
                        hidewhen "{ p1type_# != 50 pre1type_# != 50 pre2type_# != 50 v1type_# != 50 v2type_# != 50 v3type_# != 50 v4type_# != 50 v5type_# != 50 }"
                        range   { -1 1 }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "cpow_#"
                        label   "pow/r/i CPOW"
                        type    vector
                        size    3
                        default { "2" "1" "0.25" }
                        help    "\\nPOWER, R, I"
