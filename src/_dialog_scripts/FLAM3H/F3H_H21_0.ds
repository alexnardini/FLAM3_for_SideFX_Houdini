{
    name	parameters
    groupsimple {
        name    "f_flam3h_global"
        label   "global"
        disablewhentab "{ flamefunc == 0 } { h_valid == 0 }"
        grouptag { "group_type" "simple" }

        parm {
            name    "icon_iter_off"
            label   "Iterations OFF"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "The iterations number to use to resolve this fractal Flame."
            disablewhen "{ aboutdisable == 1 }"
            hidewhen "{ flamefunc > 0 }"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionDisabledZeroIterSVG.svg" }
            parmtag { "script_callback" "" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "iter_off"
            label   "iterations"
            type    integer
            nolabel
            joinnext
            default { "10" }
            help    "The iterations number to use to resolve this fractal Flame."
            disablewhen "{ gpu == 1 }"
            hidewhen "{ flamefunc > 0 }"
            range   { 1! 128 }
            parmtag { "script_callback" "" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "ptcount_presets_off"
            label   "density presets off"
            type    ordinal
            nolabel
            default { "0" }
            hidewhen "{ flamefunc > 0 }"
            menu {
                "0" "![opdef:/alexnardini::Sop/FLAM3H?icon_optionDisabledZeroIterSVG.svg]"
                "1" "![opdef:/alexnardini::Sop/FLAM3H?icon_optionDisabledZeroIterSVG.svg]1 Billion"
            }
            parmtag { "script_action" "n = None" }
            parmtag { "script_action_help" "Reset density OFF" }
            parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionDisabledZeroIterSVG.svg" }
            parmtag { "script_callback" "" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "icon_iter"
            label   "Iterations"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "FLAM3H™ is running in CPU(CVEX) mode.\\n\\n[LMB]\\nto switch to the GPU mode.\\n\\nThe iterations number to use to resolve this fractal Flame.\\n\\nYou must experiment with the number of iterations\\nand always go as low as possible to save on execution time.\\nYou went too low when the fractal Flame start to turn blocky,\\nwhich happens when it crosses its own minimum.\\n\\nIt is advised that occasionally you bump up this number a little\\nto see if there is anything you are overlooking.\\n\\nFor instance,\\ncertain Flames can seem completely different with higher number of iterations."
            hidewhen "{ flamefunc == 0 } { gpu == 1 }"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarBlueSVG.svg" }
            parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).cpu_switch_to_gpu()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "icon_iter_gpu"
            label   "Iterations"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "FLAM3H™ is running in GPU mode.\\n\\n[LMB]\\nto cycle through the available GPU iterations presets.\\nPresets are: 128, 256, 512, 1024, 2048, 4096.\\nIt will cycle backward.\\n\\n[SHIFT+LMB]\\nIt will cycle forward.\\n\\n[CTRL+LMB]\\nIt will switch to the CPU(Cvex) mode.\\nWhen switching to CPU(Cvex) mode for the very first time,\\nHoudini will compile all the FLAM3H™ CPU(CVEX) nodes.\\nDepending on your PC configuration it can take up to 1(one) minute.\\nIt is a one time compile process.\\n\\nAdditionally,\\nyou can change the number of iterations being used by the GPU\\nin the preferences tab under the GPU section.\\n\\nNOTE:\\nEverytime you either:\\n- load a Flame preset\\n- reset FLAM3H™ to the Sierpiński triangle\\n- set its iterator's count to 0(Zero)\\nthe GPU iterations will be reset to its default value of: 1024"
            hidewhen "{ flamefunc == 0 } { gpu == 0 }"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionToolOCLSVG.svg" }
            parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).gpu_iterations_cycle()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "iter"
            label   "iterations"
            type    integer
            nolabel
            joinnext
            default { "10" }
            help    "The iterations number to use to resolve this fractal Flame."
            disablewhen "{ gpu == 1 }"
            hidewhen "{ flamefunc == 0 }"
            range   { 1! 128 }
            parmtag { "script_callback" "hou.phm().flam3.out_flame_utils(kwargs).out_auto_change_iter_num_to_prm()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "ptcount_presets"
            label   "density presets"
            type    ordinal
            nolabel
            default { "1" }
            hidewhen "{ flamefunc == 0 }"
            menu {
                [ "menu = hou.phm().flam3.flam3h_iterator_utils(kwargs).menu_global_density()" ]
                [ "return menu" ]
                language python
            }
            parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_iterator_utils(kwargs).menu_global_density_set_default()" }
            parmtag { "script_action_help" "[LMB] to reset density to its default: 500k(thousands) points. This is what should be used while editing fractal Flames most of the time. When using a custom density value from inside the preferences tab's density parameter this menu will become empty to signal it otherwise it will always show the menu label you selected. Additionally: [SHIFT+LMB] set density to: 300k(thousands). [CTRL+LMB] set density to: 200k(thousands). [ALT+LMB] set density to: 100k(thousands)" }
            parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarWhiteToolSVG.svg" }
            parmtag { "script_callback" "hou.phm().flam3.flam3h_iterator_utils(kwargs).menu_global_density_set()" }
            parmtag { "script_callback_language" "python" }
        }
    }

    groupsimple {
        name    "f_flam3h_sys"
        label   "sys"
        disablewhentab "{ h_valid == 0 }"
        grouptag { "group_type" "simple" }

        parm {
            name    "sys_help"
            label   "FLAM3H™ Documentation"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "Display FLAM3H™ Documentation"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_F_docStarSVG.svg" }
            parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_display_help(), kwargs['parm'].deleteAllKeyframes()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "empty_sys_01"
            label   "empty"
            type    geometrydata
            nolabel
            joinnext
            default { "0" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "iterlist"
            label   "Iterator list"
            type    ordinal
            nolabel
            joinnext
            default { "0" }
            menumini {
                [ "menu = hou.phm().flam3.flam3h_iterator_utils(kwargs).menu_select_iterator()" ]
                [ "return menu" ]
                language python
            }
            parmtag { "script_callback" "hou.phm().flam3.flam3h_iterator_utils(kwargs).prm_select_iterator(), kwargs['parm'].deleteAllKeyframes()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "empty_sys_02"
            label   "empty"
            type    geometrydata
            nolabel
            joinnext
            default { "0" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "doff_no_iterators"
            label   "FF OFF"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "FF"
            disablewhen "{ flamefunc == 0 }"
            hidewhen "{ flamefunc > 0 }"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionDisabledZeroIterSVG.svg" }
            parmtag { "script_callback" "" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "doff_sysdisabled"
            label   "FF Disabled"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "ON by default.\\nAllow you to Enable or Disable the FF (finalXform).\\n\\nFor example this FF is now Disabled. [LMB] to Enable it.\\n\\nIterators like Final Flame (FF) or finalXform function like camera lenses.\\nIt allows for a great deal of creative experimentation by taking the combined result of all the iterators inside the FLAME Tab and applying further modifications to that result.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
            disablewhen "{ flamefunc == 0 }"
            hidewhen "{ flamefunc == 0 } { doff == 1 }"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionFFDisabledSVG.svg" }
            parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_toggle_private_FF(), kwargs['parm'].deleteAllKeyframes()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "doff_sysenabled"
            label   "FF Enabled"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "ON by default.\\nAllow you to Enable or Disable the FF (finalXform).\\n\\nFor example this FF is now Enabled. [LMB] to Disable it.\\n\\nIterators like Final Flame (FF) or finalXform function like camera lenses.\\nIt allows for a great deal of creative experimentation by taking the combined result of all the iterators inside the FLAME Tab and applying further modifications to that result.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
            disablewhen "{ flamefunc == 0 }"
            hidewhen "{ flamefunc == 0 } { doff == 0 }"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionFFEnabledSVG.svg" }
            parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_toggle_private_FF(), kwargs['parm'].deleteAllKeyframes()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "rip_no_iterators"
            label   "RIP OFF"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "RIP"
            disablewhen "{ flamefunc == 0 } { outsensor == 1 }"
            hidewhen "{ flamefunc > 0 outsensor == 0 }"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionDisabledZeroIterSVG.svg" }
            parmtag { "script_callback" "" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "rip_disabled"
            label   "RIP Disabled"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "Enable RIP\\n\\nRemove invalid points. INF, NAN, Zero Opacity and out-of-bounds points.\\n\\nAfter the algorithm transforms the points,\\nit is possible for some of those points to shoot to infinity.\\n\\nTurn this ON while rendering ( particularly for a sequence )\\nto correct any failed or black frames that may appear.\\n\\nIf rendering a flame seems unusually slow,\\nit’s probably because certain points wind up being really far from the zero world.\\nThose points will be eliminated if this option is turned ON.\\n\\nTIPS:\\nThis functionality is CPU only.\\nWhen in GPU mode, having this ON/Active will slow down\\nas it will be taxing to cleanup the incoming point cloud from the GPU nodes.\\nKeep this OFF while editing your fractal flames in GPU mode to go full speed\\nand Activate it only if/when needed: (e.g. before any rendering or to check the final result from time to time if any iterators' opacity is 0(Zero) or NaN values are present).\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
            disablewhen "{ flamefunc == 0 } { outsensor == 1 }"
            hidewhen "{ flamefunc == 0 } { rip == 1 } { outsensor == 1 }"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionRIPDisabledSVG.svg" }
            parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_toggle_private(\"rip\"), kwargs['parm'].deleteAllKeyframes()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "rip_enabled"
            label   "RIP Enabled"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "Disable RIP\\n\\nRemove invalid points. INF, NAN, Zero Opacity and out-of-bounds points.\\n\\nAfter the algorithm transforms the points,\\nit is possible for some of those points to shoot to infinity.\\n\\nTurn this ON while rendering ( particularly for a sequence )\\nto correct any failed or black frames that may appear.\\n\\nIf rendering a flame seems unusually slow,\\nit’s probably because certain points wind up being really far from the zero world.\\nThose points will be eliminated if this option is turned ON.\\n\\nTIPS:\\nThis functionality is CPU only.\\nWhen in GPU mode, having this ON/Active will slow down\\nas it will be taxing to cleanup the incoming point cloud from the GPU nodes.\\nKeep this OFF while editing your fractal flames in GPU mode to go full speed\\nand Activate it only if/when needed: (e.g. before any rendering or to check the final result from time to time if any iterators' opacity is 0(Zero) or NaN values are present).\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
            disablewhen "{ flamefunc == 0 }"
            hidewhen "{ flamefunc == 0 } { rip == 0 } { outsensor == 1 }"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionRIPEnabledSVG.svg" }
            parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_toggle_private(\"rip\"), kwargs['parm'].deleteAllKeyframes()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "f3c_no_iterators"
            label   "F3C OFF"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "F3C"
            disablewhen "{ flamefunc == 0 }"
            hidewhen "{ flamefunc > 0 }"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionDisabledZeroIterSVG.svg" }
            parmtag { "script_callback" "" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "f3c_chaotica"
            label   "F3C Chaotica"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "\\nF3C: Unchecked -> Chaotica behavior\\n\\nThe behavior of the:\\nCos, Cosh, Cot, Coth, Csc, Csch, Sec, Sech, Sin, Sinh, Tan, Tanh, Cross, Curve, Edisc, Escher, Fan2\\nvariations are different in flam3/Apophysis versus Chaotica.\\n\\nChecked: use the Apophysis behavior.\\n\\nUnchecked: use the Chaotica behavior.\\n\\nThe behavior of the:\\nBipolar, Glynnia, Julia, JuliaN, JuliaScope\\nvariations are also different in Flam3/Apophysis versus Chaotica\\nand FLAM3H™ do not implement these Chaotica variants just yet (Fractorium does).\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
            disablewhen "{ flamefunc == 0 }"
            hidewhen "{ flamefunc == 0 } { f3c == 1 }"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionF3CDisabledSVG.svg" }
            parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_toggle_private(\"f3c\"), kwargs['parm'].deleteAllKeyframes()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "f3c_apophysis"
            label   "F3C Apophysis"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "\\nF3C: Checked -> Flam3/Apophysis behavior\\n\\nThe behavior of the:\\nCos, Cosh, Cot, Coth, Csc, Csch, Sec, Sech, Sin, Sinh, Tan, Tanh, Cross, Curve, Edisc, Escher, Fan2\\nvariations are different in flam3/Apophysis versus Chaotica.\\n\\nChecked: use the Apophysis behavior.\\n\\nUnchecked: use the Chaotica behavior.\\n\\nThe behavior of the:\\nBipolar, Glynnia, Julia, JuliaN, JuliaScope\\nvariations are also different in Flam3/Apophysis versus Chaotica\\nand FLAM3H™ do not implement these Chaotica variants just yet (Fractorium does).\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
            disablewhen "{ flamefunc == 0 }"
            hidewhen "{ flamefunc == 0 } { f3c == 0 }"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionF3CEnabledSVG.svg" }
            parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_toggle_private(\"f3c\"), kwargs['parm'].deleteAllKeyframes()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "xfviz_no_iterators"
            label   "XF VIZ OFF"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "XF VIZ"
            disablewhen "{ flamefunc == 0 } { outsensor == 1 }"
            hidewhen "{ flamefunc > 0 outsensor == 0 }"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionDisabledZeroIterSVG.svg" }
            parmtag { "script_callback" "" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "xfviz_off"
            label   "xforms handles VIZ OFF"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "[LMB] to enable the xforms handles VIZ in the viewport.\\n\\nThese handles are not editable, but only for visualization purpose.\\nThey will be helpful to better grasp how the affine values (PRE and POST affine) are acting over each iterator of the fractal Flame.\\n\\nYou can adjust their wire curve thickness in the preferences tab\\nusing the prefs viewport -> \"wire width\" parameter.\\n\\nThe viewport handles will be automatically disabled\\nif the FLAM3H™ density value is raised above 5M(millions) points\\nor when the OUT camera sensor VIZ mode is ON.\\n\\nWARNING:\\nTurn this OFF when rendering.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
            disablewhen "{ flamefunc == 0 } { ptcount > 5000000 }"
            hidewhen "{ flamefunc == 0 } { vizhandles == 1 } { outsensor == 1 }"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_xfHandlesDisabledSVG.svg" }
            parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_xf_viz_toggle(), kwargs['parm'].deleteAllKeyframes()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "xfviz_on"
            label   "xforms handles VIZ ON"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "[LMB] to disable the xforms handles VIZ in the viewport.\\n\\nThese handles are not editable, but only for visualization purpose.\\nThey will be helpful to better grasp how the affine values (PRE and POST affine) are acting over each iterator of the fractal Flame.\\n\\nYou can adjust their wire curve thickness in the preferences tab\\nusing the prefs viewport -> \"wire width\" parameter.\\n\\nThe viewport handles will be automatically disabled\\nif the FLAM3H™ density value is raised above 5M(millions) points\\nor when the OUT camera sensor VIZ mode is ON.\\n\\nWARNING:\\nTurn this OFF when rendering.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
            disablewhen "{ flamefunc == 0 } { ptcount > 5000000 }"
            hidewhen "{ flamefunc == 0 } { vizhandles == 0 } { vizhandles_solo == 1 vizhandlesff_solo == 1 } { vizhandles_solo == 1 } { vizhandlesff_solo == 1 } { outsensor == 1 }"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_xfHandlesEnabledSVG.svg" }
            parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_xf_viz_toggle(), kwargs['parm'].deleteAllKeyframes()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "xfviz_on_solo"
            label   "xform handle VIZ SOLO ON"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "[LMB] to disable the xforms handles VIZ SOLO mode\\nand revert to display all xforms handles VIZ together.\\n\\nThe viewport handles will be automatically disabled\\nif the FLAM3H™ density value is raised above 5M(millions) points\\nor when the OUT camera sensor VIZ mode is ON.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
            disablewhen "{ flamefunc == 0 } { ptcount > 5000000 }"
            hidewhen "{ flamefunc == 0 } { vizhandles == 0 } { vizhandles_solo == 0 vizhandlesff_solo == 1 } { vizhandles_solo == 0 } { outsensor == 1 }"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_xfHandlesEnabledMPIDXSVG.svg" }
            parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_toggle_sys_xf_viz_solo(), kwargs['parm'].deleteAllKeyframes()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "xfvizff_on_solo"
            label   "FF handle VIZ SOLO ON"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "[LMB] to disable the xforms handles VIZ SOLO mode\\nand revert to display all xforms handles VIZ together.\\n\\nThe viewport handles will be automatically disabled\\nif the FLAM3H™ density value is raised above 5M(millions) points\\nor when the OUT camera sensor VIZ mode is ON.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
            disablewhen "{ flamefunc == 0 } { ptcount > 5000000 }"
            hidewhen "{ flamefunc == 0 } { vizhandles == 0 } { vizhandles_solo == 1 vizhandlesff_solo == 0 } { vizhandlesff_solo == 0 } { outsensor == 1 }"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_ffHandlesEnabledSVG.svg" }
            parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_toggle_sys_xf_ff_viz_solo(), kwargs['parm'].deleteAllKeyframes()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "empty_sys_03"
            label   "empty"
            type    geometrydata
            nolabel
            joinnext
            default { "0" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "sys_out_sensorviz"
            label   "SENSOR Enabled"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "EXIT sensor viz mode. Camera sensor update ON.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
            hidewhen "{ outsensor == 0 } { outsensorupdate == 0 }"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_TagORedSVG.svg" }
            parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_outsensor_toggle(), kwargs['parm'].deleteAllKeyframes()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "sys_out_sensorviz_off"
            label   "SENSOR Enabled"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "EXIT sensor viz mode. Camera sensor update OFF.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
            hidewhen "{ outsensor == 0 } { outsensorupdate == 1 }"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_TagORedOffSVG.svg" }
            parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_outsensor_toggle(), kwargs['parm'].deleteAllKeyframes()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "sys_tag_disabled"
            label   "TAG OFF"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "TAG"
            disablewhen "{ flamefunc == 0 }"
            hidewhen "{ flamefunc > 0 } { outsensor == 1 }"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionDisabledZeroIterSVG.svg" }
            parmtag { "script_callback" "" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "sys_tag_off"
            label   "TAG Disabled"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "Enable viewport TAG.\\n\\nTAG allow you to review your fractal Flame construction infos in one compact viewport string.\\nHowever, it has a cost and the default behavior is for it to be OFF.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
            disablewhen "{ outsensor == 1 }"
            hidewhen "{ flamefunc == 0 } { tag == 1 } { outsensor == 1 }"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_TagOBlueSVG_disabled.svg" }
            parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_toggle_private(\"tag\"), kwargs['parm'].deleteAllKeyframes()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "sys_tag"
            label   "TAG Enabled"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "Disable viewport TAG.\\n\\nNext to this icon on the right there is a menu to choose different tag sizes.\\n\\nTAG allow you to review your fractal Flame construction infos in one compact viewport string.\\nHowever, it has a cost and the default behavior is for it to be OFF.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
            disablewhen "{ outsensor == 1 }"
            hidewhen "{ flamefunc == 0 } { tag == 0 } { outsensor == 1 }"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_TagOBlueSVG.svg" }
            parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_toggle_private(\"tag\"), kwargs['parm'].deleteAllKeyframes()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "tagsize_no_iterators"
            label   "TAG size"
            type    ordinal
            nolabel
            joinnext
            default { "0" }
            help    "Set a different viewport tag size."
            disablewhen "{ flamefunc == 0 } { tag == 0 } { outsensor == 1 }"
            hidewhen "{ flamefunc > 0 outsensor == 0 }"
            menu {
                "0" "![opdef:/alexnardini::Sop/FLAM3H?icon_optionDisabledZeroIterSVG.svg]"
            }
            parmtag { "script_callback" "kwargs['parm'].deleteAllKeyframes()" }
            parmtag { "script_callback_language" "python" }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "tagsize"
            label   "TAG size"
            type    ordinal
            nolabel
            joinnext
            default { "0" }
            help    "Set a different viewport tag size."
            disablewhen "{ flamefunc == 0 } { tag == 0 } { outsensor == 1 }"
            hidewhen "{ flamefunc == 0 } { outsensor == 1 }"
            menu {
                "0" "![opdef:/alexnardini::Sop/FLAM3H?icon_TagOBlueMenuSmallSVG.svg] sml"
                "1" "![opdef:/alexnardini::Sop/FLAM3H?icon_TagOBlueMenuMidSVG.svg] Mid"
                "2" "![opdef:/alexnardini::Sop/FLAM3H?icon_TagOBlueMenuBigSVG.svg] BIG"
            }
            parmtag { "script_callback" "kwargs['parm'].deleteAllKeyframes()" }
            parmtag { "script_callback_language" "python" }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "empty_sys_04"
            label   "empty"
            type    geometrydata
            nolabel
            joinnext
            default { "0" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "loaddef"
            label   "Sierpiński triangle"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "Reset FLAM3H™ and load the default Sierpiński triangle preset.\\n\\nAdditionally:\\nit will also reset the FLAM3H™ UI and options toggles to their defaults including\\nthe OUT render properties (SENSOR, RENDER and CC CURVES settings).\\n\\nWhen in GPU mode,\\nit will also reset the GPU iterations to its default: 1024"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_SierpinskyDefSVG.svg" }
            parmtag { "script_callback" "hou.phm().flam3.flam3h_iterator_utils(kwargs).flam3h_default()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "empty_sys_05"
            label   "empty"
            type    geometrydata
            nolabel
            joinnext
            default { "0" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "frameview"
            label   "Frame viewport"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "Re-frame current viewport based on a centered bounding box.\\n\\n[LMB]\\nReframe keeping the current viewports type.\\n\\n[SHIFT+LMB]\\nReframe while setting the viewports to Front type.\\n\\nThis is being added because it occasionally happens that the camera viewport frames the current Flame really small due to some of its points ending up being really far away from the zero world position.\\n\\nWhen in camera sensor mode the re-frame will be based on the Camera sensor bounding box instead.\\n\\nAdditionally,\\nit will set the viewports clipping planes to proper values every time is invoked.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
            hidewhen "{ outsensor == 1 }"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_FrameBlueSVG.svg" }
            parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).util_viewport_bbox_frame(), kwargs['parm'].deleteAllKeyframes()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "frameviewsensor"
            label   "Frame viewport sensor"
            type    button
            nolabel
            joinnext
            default { "0" }
            help    "Re-frame sensor viz.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
            hidewhen "{ outsensor == 0 }"
            parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_FrameRedSVG.svg" }
            parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).util_set_front_viewer(False), kwargs['parm'].deleteAllKeyframes()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "empty_sys_06"
            label   "empty"
            type    geometrydata
            nolabel
            joinnext
            default { "0" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "sys_palettepresets_disabled"
            label   "SYS CP file contents"
            type    string
            nolabel
            joinnext
            default { "-1" }
            help    "Disabled. Select a palette preset to load. It will show the palette contained in the selected output file, if any are present. Once you add a new palette to it, this menu will update too. It will always be set to the last palette's name you saved."
            disablewhen "{ flamefunc == 0 }"
            hidewhen "{ flamefunc > 0 }"
            menumini {
                "language"  "python"
            }
            parmtag { "script_action" "n = None" }
            parmtag { "script_action_help" "CP OFF" }
            parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionDisabledZeroIterSVG.svg" }
            parmtag { "script_callback" "" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "sys_palettepresets_off"
            label   "SYS CP file contents off"
            type    string
            nolabel
            joinnext
            default { "-1" }
            help    "Select a palette preset to load. It will show the palette contained in the selected output file, if any are present. Once you add a new palette to it, this menu will update too. It will always be set to the last palette's name you saved."
            hidewhen "{ flamefunc == 0 } { cpisvalidpreset == 1 }"
            menumini {
                [ "menu = hou.phm().flam3.flam3h_palette_utils(kwargs).menu_cp_presets_empty()" ]
                [ "return menu" ]
                language python
            }
            parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_palette_utils(kwargs).json_to_flam3h_ramp()" }
            parmtag { "script_action_help" "[LMB] to load the selected CP palette preset if any. To populate this menu, load a palette *.json file first inside the CP Tab or [SHIFT+LMB] to open a floating file chooser. [CTRL+LMB] to copy the selected preset name into the \"palette name\" string parameter. [ALT+LMB] to load a palette from the Clipboard (it will import palette data from the clipboard either from a JSON data or from a full Flame preset XML data)." }
            parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionPRIDEDisabledSVG.svg" }
            parmtag { "script_callback" "hou.phm().flam3.flam3h_palette_utils(kwargs).json_to_flam3h_ramp_sys(False), kwargs['parm'].deleteAllKeyframes()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "sys_palettepresets"
            label   "SYS CP file contents"
            type    string
            nolabel
            joinnext
            default { "-1" }
            help    "Select a palette preset to load. It will show the palette contained in the selected output file, if any are present. Once you add a new palette to it, this menu will update too. It will always be set to the last palette's name you saved."
            hidewhen "{ flamefunc == 0 } { cpisvalidpreset == 0 }"
            menumini {
                [ "menu = hou.phm().flam3.flam3h_palette_utils(kwargs).menu_cp_presets()" ]
                [ "return menu" ]
                language python
            }
            parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_palette_utils(kwargs).json_to_flam3h_ramp()" }
            parmtag { "script_action_help" "[LMB] to reload the selected CP palette preset, if any. [SHIFT+LMB] to open a floating file chooser. [CTRL+LMB] to copy the selected preset name into the \"palette name\" string parameter. [ALT+LMB] to load a palette from the Clipboard (it will import palette data from the clipboard either from a JSON data or from a full Flame preset XML data)." }
            parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionCPSVG.svg" }
            parmtag { "script_callback" "hou.phm().flam3.flam3h_palette_utils(kwargs).json_to_flam3h_ramp_sys(False), kwargs['parm'].deleteAllKeyframes()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "empty_sys_07"
            label   "empty"
            type    geometrydata
            nolabel
            joinnext
            default { "0" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "sys_inpresets_disabled"
            label   "SYS IN file contents"
            type    string
            nolabel
            joinnext
            default { "-1" }
            hidewhen "{ inisvalidfile == 1 inisvalidpreset == 1 }"
            menumini {
                [ "menu = hou.phm().flam3.in_flame_utils(kwargs).menu_in_presets_empty()" ]
                [ "return menu" ]
                language python
            }
            parmtag { "script_action" "kwargs['node'].hdaModule().flam3.in_flame_utils(kwargs).in_to_flam3h()" }
            parmtag { "script_action_help" "[LMB] to load the selected IN Flame preset, if any. To populate this menu, load a Flame lib *.flame file first inside the IN Tab or [SHIFT+LMB] to open a floating file chooser. [ALT+LMB] to load a Flame from the Clipboard." }
            parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_WhiteSVG_disabled.svg" }
            parmtag { "script_callback" "hou.phm().flam3.in_flame_utils(kwargs).in_to_flam3h_sys(), kwargs['parm'].deleteAllKeyframes()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "sys_inpresets"
            label   "SYS IN file contents"
            type    string
            nolabel
            joinnext
            default { "-1" }
            hidewhen "{ inisvalidfile == 1 inisvalidpreset == 0 } { inisvalidfile == 0 }"
            menumini {
                [ "menu = hou.phm().flam3.in_flame_utils(kwargs).menu_in_presets()" ]
                [ "return menu" ]
                language python
            }
            parmtag { "script_action" "kwargs['node'].hdaModule().flam3.in_flame_utils(kwargs).in_to_flam3h()" }
            parmtag { "script_action_help" "[LMB] to reload the selected IN Flame preset, if any. [SHIFT+LMB] to open a floating file chooser. [ALT+LMB] to load a Flame from the Clipboard. " }
            parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_WhiteSVG.svg" }
            parmtag { "script_callback" "hou.phm().flam3.in_flame_utils(kwargs).in_to_flam3h_sys(), kwargs['parm'].deleteAllKeyframes()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "empty_sys_08"
            label   "empty"
            type    geometrydata
            nolabel
            joinnext
            default { "0" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "sys_outpresets_disabled"
            label   "SYS OUT file contents"
            type    string
            nolabel
            joinnext
            default { "-1" }
            disablewhen "{ flamefunc == 0 }"
            hidewhen "{ flamefunc > 0 }"
            menumini {
                "language"  "python"
            }
            parmtag { "script_action" "n = None" }
            parmtag { "script_action_help" "OUT OFF" }
            parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionDisabledZeroIterSVG.svg" }
            parmtag { "script_callback" "" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "sys_outpresets"
            label   "SYS OUT file contents"
            type    string
            nolabel
            joinnext
            default { "-1" }
            help    "This menu is only for informational purposes.\\nIt will show the Flame presets contained in the selected output file, if any are present. Once you add a new Flame to it, this menu will update too. It will always be set to the last Flame name you saved.\\n\\nIt will also print quick informations ( in the status bar and as a flash message in the network editor)\\nabout the Flame preset when one is selected.\\n\\nQuick infos are:\\n- Flame preset name ( only in the status bar )\\n- XF: Number of iterators/xforms being used\\n- FF: when finalXform(FF) is being used\\n- Palette: number of colors in the palette\\n- HSV: when HSV color correction is being used\\n- HSV values ( only in the status bar )\\n"
            hidewhen "{ flamefunc == 0 }"
            menumini {
                [ "menu = hou.phm().flam3.out_flame_utils(kwargs).menu_out_contents_presets()" ]
                [ "return menu" ]
                language python
            }
            parmtag { "script_action" "kwargs['node'].hdaModule().flam3.out_flame_utils(kwargs).out_XML()" }
            parmtag { "script_action_help" "[LMB] to save this Flame inside the selected OUT file, if any. If the file doesn't exit yet it will create it. If the file contain already some Flames, it will append it. [CTRL+LMB] to erase the content of the file and save only the current Flame in it. [SHIFT+LMB] if not a valid filepath is present already it will open a file chooser, otherwise it will open the file explorer to the file location. [ALT+LMB] to save this Flame into the Clipboard. " }
            parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_WhiteStarSVG.svg" }
            parmtag { "script_callback" "hou.phm().flam3.out_flame_utils(kwargs).out_to_flam3h_quick('SYS'), kwargs['parm'].deleteAllKeyframes()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "label_paletteplus"
            label   "label_paletteplus"
            type    label
            default { "[256+]" }
            hidewhen "{ paletteplus == 0 } { flamefunc == 0 }"
            parmtag { "sidefx::look" "block" }
        }
    }

    group {
        name    "f_flam3h"
        label   "FLAME"
        hidewhentab "{ h_valid == 0 }"

        multiswitcher {
            name    "flamefunc"
            label    "iterators"
            default 3
            parmtag { "script_callback" "hou.pwd().hdaModule().flam3.flam3h_iterator_utils(kwargs).iterators_count()" }
            parmtag { "script_callback_from_ui" "1" }
            parmtag { "script_callback_language" "python" }
            parmtag { "sidefx::multi_label" "mpmem_#" }

            parm {
                name    "mp_add_#"
                label   "Add or Delete iterator"
                type    geometrydata
                nolabel
                joinnext
                default { "0" }
                parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_iterator_utils(kwargs).add_iterator()" }
                parmtag { "script_action_help" "[LMB] to insert an iterator Before. [SHIFT+LMB] to insert an iterator After. [CTRL+LMB] to delete this iterator. NOTE: This icon is what you must use to Add and Delete iterators since it is updating all the FLAM3H internal data and each iterators' xaos string accordingly." }
                parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_AddDelIteratorSVG.svg" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "mpmem_#"
                label   "MPMEM"
                type    string
                invisible
                joinnext
                default { "#" }
                parmtag { "script_callback" "" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "mpmem_x_#"
                label   "MPMEM X"
                type    integer
                invisible
                joinnext
                default { "#" }
                range   { 0 10 }
                parmtag { "script_callback" "" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "note_#"
                label   "                  "
                type    string
                joinnext
                default { "iterator_#" }
                help    "Give this iterator a name or a short descriptive note.\\n\\nThe text you write here will be shown inside the SYS tab select iterator mini menu entries.\\n\\nNOTE:\\nIt will also be stored with the Flame preset file on Save\\nand shown inside third-party applications like Apophysis and Fractorium as the iterator's name."
                parmtag { "script_callback" "hou.phm().flam3.flam3h_iterator_utils(kwargs).destroy_data_note(), kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "prmpastesel_#"
                label   "parm paste selection"
                type    ordinal
                nolabel
                joinnext
                default { "0" }
                menumini {
                    [ "menu = hou.phm().flam3.flam3h_iterator_utils(kwargs).menu_copypaste()" ]
                    [ "return menu" ]
                    language python
                }
                parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_iterator_utils(kwargs).prm_paste()\n" }
                parmtag { "script_action_help" "[LMB] to mark this iterator for being copied. If already marked, it will unmark it. [SHIFT+LMB] to unmark this FLAM3H node's marked iterator for being copied. [ALT+LMB] to paste the marked iterator data into this iterator, even if the marked iterator lives in a different FLAM3H node. Once marked and pasted, it will paste everything but not Xaos. Use the nearby mini menu to paste only specific sections of it instead, like for example: Xaos. Additionally: [CTRL+LMB] to reset this iterator to its default values." }
                parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_StarSwapRedCopyPasteSVG.svg" }
                parmtag { "script_callback" "hou.phm().flam3.flam3h_iterator_utils(kwargs).prm_paste_sel()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "selmem_#"
                label   "Selection MEM"
                type    integer
                invisible
                nolabel
                default { "0" }
                range   { 0 10 }
                parmtag { "script_callback" "" }
                parmtag { "script_callback_language" "python" }
            }
            groupsimple {
                name    "f_itermain_#"
                label   "#"
                grouptag { "group_type" "simple" }

                parm {
                    name    "vactive_#"
                    label   "A"
                    type    toggle
                    invisible
                    default { "1" }
                    help    "Enable or disable this iterator."
                    parmtag { "script_callback" "" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "xfviz_#"
                    label   "XF VIZ (solo)"
                    type    toggle
                    invisible
                    default { "0" }
                    help    "Enable or disable this iterator."
                    parmtag { "script_callback" "" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "empty_flame_#"
                    label   "#: empty"
                    type    geometrydata
                    nolabel
                    joinnext
                    default { "0" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "doiter_disabled_#"
                    label   "Iterator Disabled"
                    type    button
                    nolabel
                    joinnext
                    default { "0" }
                    help    "ON by default.\\nAllow you to Enable or Disable this iterator.\\n\\nFor example this iterator is now Disabled. [LMB] to Enable it.\\n\\nIf an xform/iterator is disabled\\nit wont be included when saving the Flame out into a flame file.\\nIn case you still want to include the inactive iterator into the file\\nset its Weight to 0(Zero) instead.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
                    hidewhen "{ vactive_# == 1 }"
                    parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionDisabledSVG.svg" }
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_iterator_utils(kwargs).iterator_vactive_and_update(), kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "doiter_#"
                    label   "Iterator Enabled"
                    type    button
                    nolabel
                    joinnext
                    default { "0" }
                    help    "ON by default.\\nAllow you to Enable or Disable this iterator.\\n\\nFor example this iterator is now Enabled. [LMB] to Disable it.\\n\\nIf an xform/iterator is disabled\\nit wont be included when saving the Flame out into a flame file.\\nIn case you still want to include the inactive iterator into the file\\nset its Weight to 0(Zero) instead.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
                    hidewhen "{ vactive_# == 0 }"
                    parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarYellowOrangeSVG.svg" }
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_iterator_utils(kwargs).iterator_vactive_and_update(), kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "xfviz_off_#"
                    label   "xform handle VIZ SOLO OFF"
                    type    button
                    nolabel
                    joinnext
                    default { "0" }
                    help    "[LMB] to enable this iterator's xform handle VIZ only (SOLO mode).\\n\\nWhen the SYS -> \"xforms handles VIZ\" is ON this icon will become available.\\n\\nIf the FF is ON its xform handle VIZ will always be displayed\\ntogether with this iterator xform handle VIZ.\\n\\nWhen enabled (SOLO mode), it causes the iterator that is selected or picked\\nfrom the SYS tab select iterator mini-menu to be automatically configured to be in SOLO mode.\\nThis enables you to swiftly go over each one automatically.\\n\\nThe viewport handles will be automatically disabled\\nif the FLAM3H™ density value is raised above 5M(millions) points\\nor when the OUT camera sensor VIZ mode is ON.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
                    disablewhen "{ vizhandles == 0 } { vactive_# == 0 } { iw_# == 0 } { outsensor == 1 } { ptcount > 5000000 }"
                    hidewhen "{ xfviz_# == 1 }"
                    parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_xfHandlesDisabledSVG.svg" }
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_toggle_mp_xf_viz(), kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "xfviz_on_#"
                    label   "xform handle VIZ SOLO ON"
                    type    button
                    nolabel
                    joinnext
                    default { "0" }
                    help    "[LMB] to disable this iterator's xform handle VIZ SOLO mode\\nand revert to display all xforms handles VIZ together.\\n\\nIt causes the iterator that is picked from the SYS tab select iterator mini-menu\\nto be automatically configured to be in SOLO mode as well.\\nThis enables you to swiftly go over each one automatically.\\n\\nThe viewport handles will be automatically disabled\\nif the FLAM3H™ density value is raised above 5M(millions) points\\nor when the OUT camera sensor VIZ mode is ON.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
                    disablewhen "{ vizhandles == 0 } { vactive_# == 0 } { iw_# == 0 } { outsensor == 1 } { ptcount > 5000000 }"
                    hidewhen "{ xfviz_# == 0 }"
                    parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_xfHandlesEnabledMPIDXSVG.svg" }
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_toggle_mp_xf_viz(), kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "iw_#"
                    label   "    W"
                    type    float
                    default { "0.5" }
                    help    "The Weight of this iterator.\\nCalculate the likelihood that this iterator will be selected during the Chaos game.\\n\\nYou may require more iterations to correctly resolve the shapes of the fractal Flame you are working on if an iterator Weight is higher than the others."
                    disablewhen "{ vactive_# == 0 }"
                    range   { 0! 5 }
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_iterator_utils(kwargs).iterator_vactive_and_update()" }
                    parmtag { "script_callback_language" "python" }
                }
            }

            groupsimple {
                name    "f_iterxaos#"
                label   "#: xaos:"
                disablewhentab "{ vactive_# == 0 } { iw_# == 0 }"
                grouptag { "group_type" "simple" }

                parm {
                    name    "xaos_#"
                    label   "F# xaos"
                    type    string
                    nolabel
                    default { "xaos:" }
                    parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_ui_msg_utils(kwargs).ui_xaos_infos()" }
                    parmtag { "script_action_help" "[LMB] to Activate/Deactivate auto space xaos weights option. It will space the xaos weights for easy edit, read and count ( ON/OFF ). [CTRL+LMB] to display the Xaos usage informations/tips." }
                    parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarBlueToolSVG.svg" }
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_iterator_utils(kwargs).auto_set_xaos()" }
                    parmtag { "script_callback_language" "python" }
                }
            }

            groupsimple {
                name    "f_itershader_#"
                label   "#: shader"
                disablewhentab "{ vactive_# == 0 } { iw_# == 0 }"
                grouptag { "group_type" "simple" }

                parm {
                    name    "clr_#"
                    label   "location"
                    type    float
                    default { "0" }
                    help    "The color location in the ramp {0:1}."
                    range   { 0! 1! }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "clrspeed_#"
                    label   "speed"
                    type    float
                    default { "0" }
                    help    "Speed of color blending between iterations.\\nValues above 0(Zero) attract the selected color while values below 0(Zero) will repel it.\\n\\nThe correct ranges for this value should always be between -1 and 1."
                    range   { 0 1! }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "alpha_#"
                    label   "opacity"
                    type    float
                    default { "1" }
                    help    "It will be fully opaque at opacity 1(one) and completely transparent at opacity 0(Zero).\\nIt can also be used to adjust the prominence of different portions of your fractal Flame,\\nindependent of the iterator’s Weight.\\n\\nWhen an iterator's opacity is 0(Zero), you can activate the SYS Tab RIP option to get rid of those points.\\n( Since Opacity == @pscale or @widths in Solaris, you don't need them anymore )."
                    range   { 0! 1! }
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_iterator_utils.destroy_cachedUserData(kwargs['node'], 'iter_sel')" }
                    parmtag { "script_callback_language" "python" }
                }
            }

