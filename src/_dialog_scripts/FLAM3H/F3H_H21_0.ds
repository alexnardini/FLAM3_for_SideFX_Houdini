    group {
        name    "f_flam3h_1"
        label   "FF"
        hidewhentab "{ flamefunc == 0 } { h_valid == 0 }"

        groupsimple {
            name    "f_ffmain"
            label   "FF"
            grouptag { "group_type" "simple" }

            parm {
                name    "empty_ff_01"
                label   "empty"
                type    geometrydata
                nolabel
                joinnext
                default { "0" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "doff_disabled"
                label   "FF Disabled"
                type    button
                nolabel
                joinnext
                default { "0" }
                help    "ON by default.\\nAllow you to Enable or Disable the FF (finalXform).\\n\\nFor example this FF is now Disabled. [LMB] to Enable it.\\n\\nIterators like Final Flame (FF) or finalXform function like camera lenses.\\nIt allows for a great deal of creative experimentation by taking the combined result of all the iterators inside the FLAME Tab and applying further modifications to that result.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
                disablewhen "{ flamefunc == 0 }"
                hidewhen "{ flamefunc == 0 } { doff == 1 }"
                parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionFFDisabledSVG.svg" }
                parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_toggle_private_FF(), kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "doff_enabled"
                label   "FF Enabled"
                type    button
                nolabel
                joinnext
                default { "0" }
                help    "ON by default.\\nAllow you to Enable or Disable the FF (finalXform).\\n\\nFor example this FF is now Enabled. [LMB] to Disable it.\\n\\nIterators like Final Flame (FF) or finalXform function like camera lenses.\\nIt allows for a great deal of creative experimentation by taking the combined result of all the iterators inside the FLAME Tab and applying further modifications to that result.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
                disablewhen "{ flamefunc == 0 }"
                hidewhen "{ flamefunc == 0 } { doff == 0 }"
                parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionFFEnabledSVG.svg" }
                parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_toggle_private_FF(), kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "xfvizff_off"
                label   "FF handle VIZ SOLO OFF"
                type    button
                nolabel
                joinnext
                default { "0" }
                help    "[LMB] to enable the FF xform handle VIZ only (SOLO mode).\\n\\nWhen the SYS -> \"xforms handles VIZ\" is ON this icon will become available.\\n\\nThe viewport handles will be automatically disabled\\nif the FLAM3H™ density value is raised above 5M(millions) points.\\nor when the OUT camera sensor VIZ mode is ON.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
                disablewhen "{ vizhandles == 0 } { doff == 0 } { outsensor == 1 } { ptcount > 5000000 }"
                hidewhen "{ vizhandlesff_solo == 1 }"
                parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_xfHandlesDisabledSVG.svg" }
                parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_toggle_xf_ff_viz(), kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "xfvizff_on"
                label   "FF handle VIZ SOLO ON"
                type    button
                nolabel
                joinnext
                default { "0" }
                help    "[LMB] to disable the FF xform handle VIZ SOLO mode\\nand revert to display all xforms handles VIZ together.\\n\\nThe viewport handles will be automatically disabled\\nif the FLAM3H™ density value is raised above 5M(millions) points.\\nor when the OUT camera sensor VIZ mode is ON.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
                disablewhen "{ vizhandles == 0 } { outsensor == 1 } { ptcount > 5000000 }"
                hidewhen "{ vizhandlesff_solo == 0 }"
                parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_ffHandlesEnabledSVG.svg" }
                parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_toggle_xf_ff_viz(), kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "empty_ff_02"
                label   "empty"
                type    geometrydata
                nolabel
                default { "0" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "ffnote"
                label   "FF note"
                type    string
                nolabel
                joinnext
                default { "iterator_FF" }
                parmtag { "script_callback" "hou.phm().flam3.flam3h_iterator_utils(kwargs).note_FF(), kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "ffprmpastesel"
                label   "FF parm paste selection"
                type    ordinal
                joinnext
                default { "0" }
                menumini {
                    [ "menu = hou.phm().flam3.flam3h_iterator_utils(kwargs).menu_copypaste_FF()" ]
                    [ "return menu" ]
                    language python
                }
                parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_iterator_utils(kwargs).prm_paste_FF()" }
                parmtag { "script_action_help" "[LMB] to mark this FF for being copied. If already marked, it will unmark it. [SHIFT+LMB] will unmark this FF for being copied. [ALT+LMB] to paste the marked FF data inside a different FLAM3H node's FF. Once marked use the nearby mini menu on another FLAM3H node to paste only specific sections of it instead. Additionally: [CTRL+LMB] to reset this FF to its default values." }
                parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_StarSwapRedCopyPasteFFSVG.svg" }
                parmtag { "script_callback" "hou.phm().flam3.flam3h_iterator_utils(kwargs).prm_paste_sel_FF()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "ffselmem"
                label   "Selection MEM"
                type    integer
                invisible
                nolabel
                default { "0" }
                range   { 0 10 }
                parmtag { "script_callback_language" "python" }
            }
        }

