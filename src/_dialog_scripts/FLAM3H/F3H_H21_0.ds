            parm {
                name    "ffp2weight"
                label   "   w"
                type    float
                default { "0" }
                help    "The weight of the FF_POST_var_02.\\n\\nSet it to 0(Zero) to disable it.\\nCan be set higher than 1(one)."
                range   { 0! 1 }
                parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_iterator_utils(kwargs).swap_FF_post_vars()\n" }
                parmtag { "script_action_help" "[LMB] to swap the order of the POST Variations and their weights. [CTRL+LMB] to swap the variation's names only." }
                parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarWhiteKwargsSVG.svg" }
                parmtag { "script_callback_language" "python" }
            }
        }

        groupcollapsible {
            name    "f_ffpostaffinedo"
            label   "FF: post affine"
            disablewhentab "{ doff == 0 }"
            grouptag { "group_type" "collapsible" }
            parmtag { "sidefx::header_toggle" "ffdopost" }

            parm {
                name    "ffdopost"
                label   "FF post"
                type    toggle
                default { "0" }
                help    "OFF by default.\\nEnable FF post affine"
                parmtag { "script_callback_language" "python" }
            }
        }

        group {
            name    "f_ffpreaffine"
            label   "FF: pre affine"

            groupsimple {
                name    "f_ffpreaffinedata"
                label   "FF PRE AFFINE"
                disablewhentab "{ doff == 0 }"
                grouptag { "group_type" "simple" }

                parm {
                    name    "ffscl"
                    label   "Scale"
                    type    float
                    default { "1" }
                    help    "Scale FF pre affine values (X and Y) by an amount, with a value of 1 (100% -> no scale) being the default.\\n\\nThe are two ways to use this parameter:\\n- Input a value into the numeric field. For example if you type: 1.2 it will scale the affine up by 20%.\\n- [LMB] into the numeric field and use the mouse wheel to increment the scale up and down.\\n\\nWhen using the mouse wheel:\\n- [mouse wheel] will scale the value by an increment of: +/- 0.1\\n- [SHIFT] + [mouse wheel] will scale the value by an increment of: +/- 0.01\\n- [CTRL] + [mouse wheel] will scale the value by an increment of: +/- 1\\n\\nAdditionally:\\nThe parameter's slider ranges are between 0.975 and 1.025 to allow for precise and very small value changes when dragged left or right.\\n\\nNOTE:\\nThis parameter can not be animated.\\nEvery time you either input a value, drag the slider or use the mouse wheel to increment the value, it will revert back to the default value of 1 (100% -> no scale)."
                    range   { 0.975 1.025 }
                    parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_iterator_utils(kwargs).prm_paste_sel_pre_affine_FF()" }
                    parmtag { "script_action_help" "[LMB] to copy the values from the FF POST Affine into here, the FF PRE Affine. It will copy: X, Y, O and Rot. Additionally: [SHIFT+LMB] to copy only the X and Y values. [CTRL+LMB] to copy only the O value. [ALT+LMB] to copy only the Rotation angle value." }
                    parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_StarSwapRedCopyPasteAffineFFSVG.svg" }
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_iterator_utils(kwargs).iterator_FF_affine_scale()" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "ffx"
                    label   "X"
                    type    vector2
                    size    2
                    default { "1" "0" }
                    help    "FF pre: X.x, X.y ( A, D )"
                    range   { -1 1 }
                    parmtag { "script_callback" "" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "ffy"
                    label   "Y"
                    type    vector2
                    size    2
                    default { "0" "1" }
                    help    "FF pre: Y.x, Y.y ( B, E )"
                    range   { -1 1 }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "ffo"
                    label   "O"
                    type    vector2
                    size    2
                    default { "0" "0" }
                    help    "FF pre (offset): O.x, O.y ( C, F )"
                    range   { -1 1 }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "ffang"
                    label   "Rot"
                    type    float
                    default { "0" }
                    help    "Rotate FF pre affine in angle degrees.\\nThe rotation will take the values of X, Y, O and apply a rotation (with O being the pivot).\\n\\nNote:\\nthe resulting affine coefficients are not updated in the UI but passed directly internally to the algorithm."
                    range   { -90 90 }
                    parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_iterator_utils(kwargs).reset_preaffine_FF()" }
                    parmtag { "script_action_help" "[LMB] to reset all affine values. [SHIFT+LMB] to reset only the affine X and Y values. [CTRL+LMB] to reset only the affine O value. [ALT+LMB] to reset only the affine Rotation angle value." }
                    parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarWhiteKwargsSVG.svg" }
                    parmtag { "script_callback_language" "python" }
                }
            }

        }

