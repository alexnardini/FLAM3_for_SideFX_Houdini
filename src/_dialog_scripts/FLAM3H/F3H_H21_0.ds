                    type    vector2
                    size    2
                    default { "1.5" "1.5" }
                    help    "\\nINSIDE X, INSIDE Y"
                    hidewhen "{ ffpre1type != 71 ffp1type != 71 ffp2type != 71 }"
                    range   { 0 4 }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "fp1_splitxyz"
                    label   "xy SPLIT"
                    type    vector2
                    size    2
                    default { "4" "1" }
                    help    "\\nX, Y"
                    hidewhen "{ ffpre1type != 72 ffp1type != 72 ffp2type != 72 }"
                    range   { 0 8 }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "fp1_splitsxyz"
                    label   "xy SPLITS"
                    type    vector2
                    size    2
                    default { "1" "1" }
                    help    "\\nX, Y"
                    hidewhen "{ ffpre1type != 73 ffp1type != 73 ffp2type != 73 }"
                    range   { 0 2 }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "fp1_stripes"
                    label   "space/warp STRIPES"
                    type    vector2
                    size    2
                    default { "0.5" "0" }
                    help    "\\nSPACE, WARP"
                    hidewhen "{ ffpre1type != 74 ffp1type != 74 ffp2type != 74 }"
                    range   { 0 2 }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "fp1_supershape"
                    label   "m/r/h SUPERSHAPE"
                    type    vector
                    size    3
                    default { "6" "0" "2" }
                    help    "\\nM, RANDOM, HOLES"
                    hidewhen "{ ffpre1type != 48 ffp1type != 48 ffp2type != 48 }"
                    range   { -1 1 }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "fp1_supershapen"
                    label   "n SUPERSHAPE"
                    type    vector
                    size    3
                    default { "1" "1" "1" }
                    help    "\\nN"
                    hidewhen "{ ffpre1type != 48 ffp1type != 48 ffp2type != 48 }"
                    range   { -1 1 }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "fp1_waves2scalexyz"
                    label   "scale xy WAVES2"
                    type    vector2
                    size    2
                    default { "1" "1" }
                    help    "\\nSCALE X, SCALE Y"
                    hidewhen "{ ffpre1type != 79 ffp1type != 79 ffp2type != 79 }"
                    range   { 0 2 }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "fp1_waves2freqxyz"
                    label   "freq xy WAVES2"
                    type    vector2
                    size    2
                    default { "1" "1" }
                    help    "\\nFREQUENCY X, FREQUENCY Y"
                    hidewhen "{ ffpre1type != 79 ffp1type != 79 ffp2type != 79 }"
                    range   { 0 2 }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "fp1_wedge"
                    label   "s/a/h/c WEDGE"
                    type    vector4
                    size    4
                    default { "0" "1.5708" "0" "2" }
                    help    "\\nSWIRL, ANGLE, HOLE, COUNT"
                    hidewhen "{ ffpre1type != 75 ffp1type != 75 ffp2type != 75 }"
                    range   { 0 1 }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "fp1_wedgejulia"
                    label   "p/a/d/c WEDGEJULIA"
                    type    vector4
                    size    4
                    default { "1" "0" "0" "1" }
                    help    "\\nPOWER, ANGLE, DISTANCE, COUNT"
                    hidewhen "{ ffpre1type != 76 ffp1type != 76 ffp2type != 76 }"
                    range   { 0 10 }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "fp1_wedgesph"
                    label   "s/a/h/c WEDGESPH"
                    type    vector4
                    size    4
                    default { "0" "1.5708" "0" "1.5708" }
                    help    "\\nSWIRL, ANGLE, HOLE, COUNT"
                    hidewhen "{ ffpre1type != 77 ffp1type != 77 ffp2type != 77 }"
                    range   { 0 1 }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "fp1_whorl"
                    label   "in/out WHORL"
                    type    vector2
                    size    2
                    default { "3" "0.5" }
                    help    "\\nIN, OUT"
                    hidewhen "{ ffpre1type != 78 ffp1type != 78 ffp2type != 78 }"
                    range   { 0 6 }
                    parmtag { "script_callback_language" "python" }
                }
            }

        }

    }

    group {
        name    "f_flam3h_2"
        label   "CP"
        hidewhentab "{ flamefunc == 0 } { h_valid == 0 }"

        parm {
            name    "cpdisable"
            label   "disable"
            type    toggle
            invisible
            default { "1" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "cpisvalidfile"
            label   "is valid file"
            type    toggle
            invisible
            default { "0" }
            disablewhen "{ cpdisable == 1 }"
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "cpisvalidpreset"
            label   "is valid preset"
            type    toggle
            invisible
            default { "0" }
            disablewhen "{ cpdisable == 1 }"
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "hide_palette"
            label   "Hide Palette"
            type    toggle
            invisible
            default { "1" }
            disablewhen "{ cpdisable == 1 }"
            parmtag { "script_callback_language" "python" }
        }
        groupsimple {
            name    "f_cphsv"
            label   "CP HSV"
            grouptag { "group_type" "simple" }

            parm {
                name    "hsv"
                label   "HSV"
                type    vector
                size    3
                default { "1" "1" "1" }
                help    "Hue, Saturation and Value of the palette's colors.\\n\\nHSV values are exported into the palette preset on save\\nand also into the XML on Flame save when they are used."
                range   { 0! 1 }
                parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_palette_utils(kwargs).reset_CP(2)" }
                parmtag { "script_action_help" "[LMB] to reset the HSV parameters to their default values." }
                parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarWhiteSVG.svg" }
                parmtag { "script_callback" "hou.phm().flam3.flam3h_palette_utils(kwargs).palette_hsv()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "keephsv"
                label   "keep on Load"
                type    toggle
                default { "0" }
                help    "OFF by default.\\nWhen loading a palette, FLAM3H™ will either set the HSV values to the one stored into the loaded palette preset, or reset them to their defaults otherwise.\\n\\nToggle this option ON to keep the current HSV values untouched after loading a palette preset."
                parmtag { "script_callback" "kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
        }

        groupcollapsible {
            name    "f_cphsvpalette"
            label   "CP HSV palette - viz only"
            grouptag { "group_type" "collapsible" }

            parm {
                name    "palettehsv"
                label   "palette HSV"
                type    ramp_rgb
                default { "5" }
                help    "The palette color corrected by the HSV values for viz."
                range   { 1! 10 }
                parmtag { "rampcolordefault" "1pos ( 0 ) 1c ( 0.20000000298023224 0.05000000074505806 1 ) 1interp ( linear ) 2pos ( 0.25 ) 2c ( 0.10000000149011612 0.85000002384185791 1 ) 2interp ( linear ) 3pos ( 0.5 ) 3c ( 0.05000000074505806 1 0.10000000149011612 ) 3interp ( linear ) 4pos ( 0.75 ) 4c ( 0.94999998807907104 1 0.10000000149011612 ) 4interp ( linear ) 5pos ( 1 ) 5c ( 1 0.05000000074505806 0.05000000074505806 ) 5interp ( linear )" }
                parmtag { "rampshowcontrolsdefault" "0" }
                parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_palette_utils(kwargs).palette_cp()" }
                parmtag { "script_action_help" "[LMB] to Update HSV palette." }
                parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarWhiteSVG.svg" }
                parmtag { "script_callback" "hou.phm().flam3.flam3h_palette_utils(kwargs).palette_lock()" }
                parmtag { "script_callback_language" "python" }
            }
        }

        groupsimple {
            name    "f_cppalette"
            label   "CP palette"
            grouptag { "group_type" "simple" }

            parm {
                name    "cp_bases"
                label   "Bases"
                type    ordinal
                nolabel
                joinnext
                default { "0" }
                help    "Select between different lookup samples interpolation methods (bases)"
                menu usetokenvalue {
                    "0" "![CHANNELS_linear] linear"
                    "1" "![CHANNELS_constant] constant"
                    "2" "![CHANNELS_ease] cubic"
                    "3" "![CHANNELS_bezier] bezier"
                    "4" "![CHANNELS_b_spline] bspline"
                    "5" "![CHANNELS_hermite] hermite"
                }
                parmtag { "script_callback" "hou.phm().flam3.flam3h_palette_utils(kwargs).cp_bases_selection_msg(), kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
                parmtag { "sidefx::look" "icon" }
            }
            parm {
                name    "cp_lookupsamples"
                label   "lookup samples"
                type    ordinal
                nolabel
                joinnext
                default { "256" }
                menu usetokenvalue {
                    "256"   "![opdef:/alexnardini::Sop/FLAM3H?icon_optionStarWhiteSVG.svg]256"
                    "512"   "![opdef:/alexnardini::Sop/FLAM3H?icon_optionEnabledSVG.svg]512"
                    "1024"  "![opdef:/alexnardini::Sop/FLAM3H?icon_optionEnabledHighSVG.svg]1024     "
                }
                parmtag { "script_callback" "kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "cp_lookupsamples_label"
                label   " samples"
                type    data
                default { "0" }
                help    "256 by default.\\nThe amount of lookup samples to use to sample this palette.\\n\\nNext to this menu on its left side you can find a mini-menu to allow you to choose between different interpolation methods for the lookup samples color keys values. Keep in mind that these are interpolation methods between the lookup samples that are used to sample the palette, not between the color keys of the palette itself.\\n\\nLookup samples have no connection on the palette you design. Only a few color keys can be made;\\nnevertheless, the palette will be internally sampled (linearly spaced) from ZERO (start) to ONE (end) using this amount of samples.\\n\\nThe amount of linearly spaced color keys in a typical fractal Flame is equivalent to 256,\\nwhich is the default.\\n\\nHowever,\\nif you create a palette with more than 256 color keys you might eventually want to use an higher amount of samples to be sure to catch all the subtle color variations of the palette.\\nIn general, 256 lookup samples will always be good.\\n\\nSaving out a Flame into a file, will also save the palette lookup samples value so that you can restore it once you load the Flame back into FLAM3H™.\\n\\nIf the file do not posses a lookup samples XML key, the default value of 256 will be used instead.\\n\\nSaving a Flame out will always save the palette with 256 color's keys.\\nIf you created a palette with more than 256 colors, for example with 1024 color keys and sample it with 1024 samples to take into account all the subtle color changes,\\nturn ON the Preferences general option -> \"palette 256+\" toggle (it is ON by default)."
                parmtag { "script_callback" "" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "palette"
                label   "palette"
                type    ramp_rgb
                default { "5" }
                help    "The source palette."
                range   { 1! 10 }
                parmtag { "rampcolordefault" "1pos ( 0 ) 1c ( 0.20000000298023224 0.05000000074505806 1 ) 1interp ( linear ) 2pos ( 0.25 ) 2c ( 0.10000000149011612 0.85000002384185791 1 ) 2interp ( linear ) 3pos ( 0.5 ) 3c ( 0.05000000074505806 1 0.10000000149011612 ) 3interp ( linear ) 4pos ( 0.75 ) 4c ( 0.94999998807907104 1 0.10000000149011612 ) 4interp ( linear ) 5pos ( 1 ) 5c ( 1 0.05000000074505806 0.05000000074505806 ) 5interp ( linear )" }
                parmtag { "rampshowcontrolsdefault" "0" }
                parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_palette_utils(kwargs).reset_CP_palette_action()" }
                parmtag { "script_action_help" "[LMB] to Reset the palette to its default values. This has also the important property to remove and clear all keyframes/expressions if any in this Palette and/or in the HSV Palette as well. [CTRL+LMB] to only remove and clear all keyframes/expressions if any in this Palette and/or in the HSV Palette as well, keeping them both untouched." }
                parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarWhiteToolSVG.svg" }
                parmtag { "script_callback" "hou.phm().flam3.flam3h_palette_utils(kwargs).palette_cp(True)" }
                parmtag { "script_callback_language" "python" }
            }
        }

        groupsimple {
            name    "f_cptmppalette"
            label   "CP palette tmp"
            invisibletab
            grouptag { "group_type" "simple" }

            parm {
                name    "palettetmp"
                label   "palette temp"
                type    ramp_rgb
                default { "2" }
                help    "The temporary palette.\\n\\nThis palette is used as a clone of the palette loaded from a palette preset file and used to compare and understand if the user made any modification to the loaded palette preset."
                range   { 1! 10 }
                parmtag { "rampcolordefault" "1pos ( 0 ) 1c ( 0.99899899959564209 0 0 ) 1interp ( linear ) 2pos ( 1 ) 2c ( 0.99899899959564209 0 0 ) 2interp ( linear )" }
                parmtag { "rampshowcontrolsdefault" "0" }
                parmtag { "script_callback" "" }
                parmtag { "script_callback_language" "python" }
            }
        }

        groupsimple {
            name    "f_cppresets"
            label   "CP presets"
            grouptag { "group_type" "simple" }

            parm {
                name    "palettefile"
                label   "JSON file"
                type    file
                default { "" }
                help    "Load an already created FLAM3H™ json palette library file\\nor choose the path and name of a new one to create."
                parmtag { "filechooser_pattern" "*.json" }
                parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_init_presets_CP_PRESETS(), kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "palettename"
                label   "palette name"
                type    string
                default { "" }
                help    "Save this palette with this name.\\nIf no name is provided, a default name composed of today's date and current time will be used instead."
                parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_palette_utils(kwargs).flam3h_ramp_save()" }
                parmtag { "script_action_help" "[LMB] to save this Palette inside the selected file. If the file doesn't exit yet it will create it. If the file contain already some palette, it will append it. [CTRL+LMB] to erase the content of the file and save only the current Palette in it. [SHIFT+LMB] if not a valid filepath is present already it will open a file chooser, otherwise it will open the file explorer to the file location. If the selected file is not a valid Palette JSON file type, nothing will happen. [ALT+LMB] to save the current palette into the Clipboard as a JSON data." }
                parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_WhiteStarSVG.svg" }
                parmtag { "script_callback" "hou.phm().flam3.flam3h_palette_utils(kwargs).cp_preset_name_set(), kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "palettepresets_off"
                label   "CP file contents"
                type    string
                default { "-1" }
                help    "\\nNo preset loaded.\\n\\nSelect a palette preset to load.\\nAs many entries as there are palette in the file you are loading will be added to this preset menu, if any are present.\\n\\nOnce you add a new palette preset to it, this menu will update too.\\nIt will always be set to the last palette's name you saved."
                hidewhen "{ cpisvalidpreset == 1 }"
                menu {
                    [ "menu = hou.phm().flam3.flam3h_palette_utils(kwargs).menu_cp_presets_empty()" ]
                    [ "return menu" ]
                    language python
                }
                parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_palette_utils(kwargs).json_to_flam3h_ramp()" }
                parmtag { "script_action_help" "[LMB] to load the selected CP palette preset if any. To populate this menu, load a palette *.json file first inside the CP Tab or [SHIFT+LMB] to open a floating file chooser. [CTRL+LMB] to copy the selected preset name into the \"palette name\" string parameter. [ALT+LMB] to load a palette from the Clipboard (it will import palette data from the clipboard either from a JSON data or from a full Flame preset XML data)." }
                parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionPRIDEDisabledSVG.svg" }
                parmtag { "script_callback" "hou.phm().flam3.flam3h_palette_utils(kwargs).json_to_flam3h_ramp(False), kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "palettepresets"
                label   "CP file contents"
                type    string
                default { "-1" }
                help    "\\nPreset loaded.\\n\\nSelect a palette preset to load.\\nAs many entries as there are palette in the file you are loading will be added to this preset menu, if any are present.\\n\\nOnce you add a new palette preset to it, this menu will update too.\\nIt will always be set to the last palette's name you saved."
                hidewhen "{ cpisvalidpreset == 0 }"
                menu {
                    [ "menu = hou.phm().flam3.flam3h_palette_utils(kwargs).menu_cp_presets()" ]
                    [ "return menu" ]
                    language python
                }
                parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_palette_utils(kwargs).json_to_flam3h_ramp()" }
                parmtag { "script_action_help" "[LMB] to reload the selected CP palette preset, if any. [SHIFT+LMB] to open a floating file chooser. [CTRL+LMB] to copy the selected preset name into the \"palette name\" string parameter. [ALT+LMB] to load a palette from the Clipboard (it will import palette data from the clipboard either from a JSON data or from a full Flame preset XML data)." }
                parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionCPSVG.svg" }
                parmtag { "script_callback" "hou.phm().flam3.flam3h_palette_utils(kwargs).json_to_flam3h_ramp(False), kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "palettemsg"
                label   "palettemsg"
                type    label
                default { "" }
                parmtag { "sidefx::look" "block" }
            }
        }

        groupcollapsible {
            name    "f_cpoptions"
            label   "CP options"
            invisibletab
            grouptag { "group_type" "collapsible" }

            parm {
                name    "cppaletteplus"
                label   "palette 256+"
                type    toggle
                default { "1" }
                help    "ON by default.\\nIt will allow the CP Palette to be saved with more than 256 color keys assuming you created a Palette with this many colors."
                parmtag { "script_callback" "hou.phm().flam3.out_flame_utils(kwargs).out_palette_256_plus_check()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "savehsv"
                label   "palette HSV"
                type    toggle
                default { "0" }
                help    "OFF by default.\\nWhen saving out a palette, FLAM3H by default uses the non-color-corrected ramp and save the HSV values along with it if used ( different from default values ).\\n\\nIf switched ON,\\nthis option will allow you to save the color-corrected HSV ramp instead.\\nIt will also clamp the HSV palette colors on save to 0-255."
                parmtag { "script_callback_language" "python" }
            }
        }

    }

    group {
        name    "f_flam3h_3"
        label   "MB"
        disablewhentab "{ gpu == 1 }"
        hidewhentab "{ flamefunc == 0 } { h_valid == 0 }"

        groupsimple {
            name    "f_mbmain"
            label   "MB"
            grouptag { "group_type" "simple" }

            parm {
                name    "domb"
                label   "On"
                type    toggle
                default { "0" }
                help    "OFF by default.\\nTurning this ON will compute a proper temporal motion blur (centered).\\n\\nIf you animate any of the available parameters using expressions,\\nremember to always use @Time and not $F\\nso FLAM3H™ will be able to interpolate through time properly."
                parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_general_utils(kwargs).reset_MB(False)" }
                parmtag { "script_action_help" "[LMB] to reset the Motion Blur parameters to their default values." }
                parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarWhiteSVG.svg" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "fps"
                label   "fps"
                type    integer
                default { "24" }
                help    "Desired Frames Per Second.\\n\\nFrames per second (FPS) significantly impacts the appearance of motion blur in video, with lower frame rates like 24 or 30 FPS naturally exhibiting more motion blur."
                disablewhen "{ domb == 0 }"
                range   { 1! 48 }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "mbsamples"
                label   "samples"
                type    integer
                default { "16" }
                help    "Number of motion blur samples.\\n\\nHigher values increase the quality and produce a smoother blur."
                disablewhen "{ domb == 0 }"
                range   { 4! 64 }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "shutter"
                label   "shutter time"
                type    float
                default { "0.5" }
                help    "Shutter time.\\n\\nBigger shutter time creating more blur and smaller shutter time freezing motion. "
                disablewhen "{ domb == 0 }"
                range   { 0 1 }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "vizmb"
                label   "viz mb"
                type    toggle
                default { "0" }
                help    "OFF by default.\\nVisualize motion blur using color.\\n(Set the viewport background to black for better viewing).\\n\\nCauses every motion blur sample/pass to get darker outward from the center to simulate the fading away due to motion/camera shutter speed. It will modify the @Cd point attribute.\\n\\nNOTE:\\nWhen rendering, keep in mind to turn this OFF to avoid superimposing a darker color."
                disablewhen "{ domb == 0 }"
                parmtag { "script_callback_language" "python" }
            }
        }

        parm {
            name    "mp_msg"
            label   "mb_msg"
            type    label
            default { "Motion Blur is not available in GPU mode." }
            hidewhen "{ gpu == 0 }"
            parmtag { "sidefx::look" "block" }
        }
    }

    group {
        name    "f_flam3h_4"
        label   "IN"
        hidewhentab "{ h_valid == 0 }"

        parm {
            name    "indisable"
            label   "disable"
            type    toggle
            invisible
            default { "1" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "inisvalidfile"
            label   "is valid file"
            type    toggle
            invisible
            default { "0" }
            disablewhen "{ indisable == 1 }"
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "inisvalidpreset"
            label   "is valid preset"
            type    toggle
            invisible
            default { "0" }
            disablewhen "{ indisable == 1 }"
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "inclipboard"
            label   "is clipboard"
            type    toggle
            invisible
            default { "0" }
            disablewhen "{ indisable == 1 }"
            parmtag { "script_callback_language" "python" }
        }
        groupsimple {
            name    "f_inmain"
            label   "IN"
            grouptag { "group_type" "simple" }

            parm {
                name    "inpath"
                label   "IN flame"
                type    file
                default { "" }
                help    "Load *.flame files created with FLAM3H™, Fractorium, Apophysis\\nand other third-party programs able to save in a Flame file format.\\n\\nThe only restrictions are:\\nThe flames contained in the file must use the same variations included inside FLAM3 for Houdini.\\n\\nA maximum of PRE_BLUR plus 2 PRE plus 4 VARS plus 1 POST variations for each iterator are allowed\\n( for a total of 8 vars per iterator ).\\n\\nFor FF ( FinalXForm ) you have 1 PRE plus 2 VARS plus 2 POST variations available.\\n\\nIf more variations are used, the excess ones will be discarded."
                parmtag { "filechooser_mode" "read" }
                parmtag { "filechooser_pattern" "*.flame" }
                parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_init_presets_IN_PRESETS(), kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "inpresets_disabled"
                label   "IN file contents"
                type    string
                default { "-1" }
                help    "\\nNo preset loaded.\\nAs many entries as there are flames in the file you are loading will be added to this preset menu.\\n\\nEach entry will display the Flame preset' name."
                hidewhen "{ inisvalidfile == 1 inisvalidpreset == 1 }"
                menu {
                    [ "menu = hou.phm().flam3.in_flame_utils(kwargs).menu_in_presets_empty()" ]
                    [ "return menu" ]
                    language python
                }
                parmtag { "script_action" "kwargs['node'].hdaModule().flam3.in_flame_utils(kwargs).in_to_flam3h()" }
                parmtag { "script_action_help" "[LMB] to load this preset. [SHIFT+LMB] to open a floating file chooser. [ALT+LMB] to load a Flame from the Clipboard." }
                parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_WhiteSVG_disabled.svg" }
                parmtag { "script_callback" "hou.phm().flam3.in_flame_utils(kwargs).in_to_flam3h(), kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "inpresets"
                label   "IN file contents"
                type    string
                default { "-1" }
                help    "\\nPreset loaded.\\nAs many entries as there are flames in the file you are loading will be added to this preset menu.\\n\\nEach entry will display the Flame preset' name."
                hidewhen "{ inisvalidfile == 1 inisvalidpreset == 0 } { inisvalidfile == 0 }"
                menu {
                    [ "menu = hou.phm().flam3.in_flame_utils(kwargs).menu_in_presets()" ]
                    [ "return menu" ]
                    language python
                }
                parmtag { "script_action" "kwargs['node'].hdaModule().flam3.in_flame_utils(kwargs).in_to_flam3h()" }
                parmtag { "script_action_help" "[LMB] to reload this preset. [SHIFT+LMB] to open a floating file chooser. [ALT+LMB] to load a Flame from the Clipboard." }
                parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_WhiteSVG.svg" }
                parmtag { "script_callback" "hou.phm().flam3.in_flame_utils(kwargs).in_to_flam3h(), kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
        }

        groupsimple {
            name    "f_inloadprefs"
            label   "IN prefs"
            disablewhentab "{ gpu == 1 }"
            hidewhentab "{ gpu == 1 }"
            grouptag { "group_type" "simple" }

            parm {
                name    "iternumonload"
                label   "iterations on Load"
                type    integer
                default { "24" }
                help    "When loading *.flame files,\\nFLAM3H™ will load them in and automatically set the iteration number to 64, which seems like a fair amount to resolve most of them fairly well.\\n\\nHowever,\\nsometimes you just want to be quick, and you can override the iteration set on load using this value.\\n\\nNOTE:\\nThe iterations number baked into the Flame preset name will override this setting.\\n\\nTurn ON \"override iterations from Flame name\" to override the iterations number baked into the Flame preset name."
                disablewhen "{ useiteronload == 0 }"
                range   { 1! 128 }
                parmtag { "script_callback" "hou.phm().flam3.in_flame_utils(kwargs).set_iter_on_load_callback(), kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "useiteronload"
                label   "force iterations on Load"
                type    toggle
                default { "0" }
                help    "OFF by default.\\nIt will use a selected number of iterations every time it loads a Flame from a flame file, instead of the default 64.\\n\\nNOTE:\\nThe iterations number baked into the Flame preset name will override this setting.\\n\\nTurn ON \"override iterations from Flame name\" to override the iterations number baked into the Flame preset name."
                parmtag { "script_callback" "hou.phm().flam3.in_flame_utils(kwargs).use_iter_on_load_callback(), kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "oritername"
                label   "override iterations from Flame name"
                type    toggle
                default { "0" }
                help    "OFF by default.\\nOverride the iterations number baked into the Flame preset name if any."
                disablewhen "{ useiteronload == 0 }"
                parmtag { "script_callback" "hou.phm().flam3.in_flame_utils(kwargs).use_iter_on_load_callback(), kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
        }

        groupcollapsible {
            name    "f_inloadoptions"
            label   "IN options"
            grouptag { "group_type" "collapsible" }

            parm {
                name    "in_f3h_affine"
                label   "F3H affine style"
                type    toggle
                default { "1" }
                help    "ON by default.\\nUse the F3H affine style format on load if they are present.\\n\\nTo be used when loading Flame presets that posses F3H affine style format in it.\\nIf not nothing will happen and FLAM3H™ will load the Flame preset using the standard Flam3 affine style.\\n\\nF3H affine style format are useful when you rotate iterators using the Rot angle parameter and you still want to reload the Flame using the Rotation value instead of the affine transformed by that Rotation whitch can lead to values that are hard to edit once loaded.\\n\\nNOTE:\\nF3H affine style format are only available when you save a Flame preset out from FLAM3H™ using the OUT tab option's \"F3H affine style\" whitch is ON by default.\\n\\nYou need to reload the current Flame preset for this change to take effect."
                parmtag { "script_action" "kwargs['node'].hdaModule().flam3.in_flame_utils(kwargs).in_to_flam3h_toggle_f3h_affine()" }
                parmtag { "script_action_help" "[LMB] to switch ON/OFF this toggle and reload the currenlty selected IN preset right after using the new settings. [ALT+LMB] to perform the same operation but while loading a Flame from the Clipboard instead." }
                parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarWhiteToolSVG.svg" }
                parmtag { "script_callback" "kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "propertiescp"
                label   "copy render properties on Load"
                type    toggle
                default { "1" }
                help    "ON by default.\\nIt will automatically copy all the render properties (SENSOR, RENDER and CC CURVES) into the OUT render properties every time you load a Flame preset in.\\n\\nYou need to reload the current Flame preset for this change to take effect.\\n\\nNOTE:\\nAll the render properties of a Flame preset loaded from the clipboard will be automatically copied into the OUT render properties on load."
                parmtag { "script_action" "kwargs['node'].hdaModule().flam3.in_flame_utils(kwargs).in_to_flam3h_toggle(\"propertiescp\")" }
                parmtag { "script_action_help" "[LMB] to switch ON/OFF this toggle and reload the currenlty selected IN preset right after using the new settings." }
                parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarWhiteSVG.svg" }
                parmtag { "script_callback" "kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
        }

        groupsimple {
            name    "f_ininfos"
            label   "IN infos"
            hidewhentab "{ flamefunc == 0 } { inisvalidpreset == 0 }"
            grouptag { "group_type" "simple" }

            parm {
                name    "icon_in_infos"
                label   "IN Flame preset informations"
                type    button
                nolabel
                joinnext
                default { "0" }
                help    "Display informations about the loaded Flame preset.\\n\\nThose infos include all the Missing variations if any are found in the currently loaded Flame preset.\\n\\nAll of the variations that Fractorium has but FLAM3H™ does not are known as: Missing variations.\\n\\nFLAM3H™ was designed to work in tandem with Fractorium, and it makes an effort to learn as much as it can about everything that Fractorium is capable of, in this case, about all the variations he possess.\\n\\nAll of the variations that Fractorium lacks will be classified as: UNKNOWN variations."
                disablewhen "{ indisable == 1 }"
                parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarBlueSVG.svg" }
                parmtag { "script_callback" "" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "flamestats_heading"
                label   "flamestats_heading"
                type    label
                default { "" }
                disablewhen "{ indisable == 1 }"
                parmtag { "sidefx::look" "heading" }
            }
            parm {
                name    "flamestats_msg"
                label   "flamestats_msg"
                type    label
                default { "" }
                parmtag { "sidefx::look" "block" }
            }
            parm {
                name    "descriptive_msg"
                label   "descriptive_msg"
                type    label
                invisible
                default { "" }
                parmtag { "sidefx::look" "block" }
            }
        }

        groupcollapsible {
            name    "f_inrenderoptions"
            label   "IN render properties"
            hidewhentab "{ flamefunc == 0 } { inisvalidpreset == 0 }"
            grouptag { "group_type" "collapsible" }
            parmtag { "sidefx::header_parm" "cprendervals" }

            parm {
                name    "cprendervals"
                label   "Copy ALL IN Flame preset render properties"
                type    button
                nolabel
                joinnext
                default { "0" }
                help    "[LMB] to copy ALL the loaded Flame preset renderer properties (SENSOR, RENDER and CC CURVES settings) intos the OUT render properties.\\n\\nAll the renderer settings of a Flame preset loaded from the clipboard will be automatically copied into the OUT renderer properties on load."
                disablewhen "{ inisvalidpreset == 0 }"
                parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_StarSwapRedCopyPasteInfosSVG.svg" }
                parmtag { "script_callback" "hou.phm().flam3.in_flame_utils.in_copy_render_all_stats_msg(kwargs, None, False, True), kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "flamerender_heading"
                label   "flamerender_heading"
                type    label
                default { "" }
                disablewhen "{ indisable == 1 }"
                parmtag { "sidefx::look" "heading" }
            }
            parm {
                name    "empty_in_01"
                label   "empty"
                type    geometrydata
                nolabel
                default { "0" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "icon_in_infos_sensor"
                label   "SENSOR"
                type    button
                default { "0" }
                help    "[LMB] to copy only the loaded Flame preset SENSOR settings intos the OUT Sensor settings.\\n\\nAll the render properties of a Flame preset loaded from the clipboard will be automatically copied into the OUT render properties on load (SENSOR, RENDER and CC CURVES settings)."
                disablewhen "{ inisvalidpreset == 0 }"
                hidewhen "{ inisvalidpreset == 0 }"
                parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_StarSwapRedCopyPasteAffineSVG.svg" }
                parmtag { "script_callback" "hou.phm().flam3.in_flame_utils.in_copy_sensor_stats_msg(kwargs)" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "flamesensor_msg"
                label   "flamesensor_msg"
                type    label
                default { "" }
                hidewhen "{ inisvalidpreset == 0 }"
                parmtag { "sidefx::look" "block" }
            }
            parm {
                name    "icon_in_infos_render"
                label   "RENDER"
                type    button
                default { "0" }
                help    "[LMB] to copy only the loaded Flame preset RENDER and CC CURVES settings intos the OUT Renderer serttings.\\n\\nAll the render properties of a Flame preset loaded from the clipboard will be automatically copied into the OUT render properties on load (SENSOR, RENDER and CC CURVES settings)."
                disablewhen "{ inisvalidpreset == 0 }"
                hidewhen "{ inisvalidpreset == 0 }"
                parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_StarSwapRedCopyPasteAffineSVG.svg" }
                parmtag { "script_callback" "hou.phm().flam3.in_flame_utils.in_copy_render_stats_msg(kwargs)" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "flamerender_msg"
                label   "flamerender_msg"
                type    label
                default { "" }
                hidewhen "{ inisvalidpreset == 0 }"
                parmtag { "sidefx::look" "block" }
            }
        }

    }

    group {
        name    "f_flam3h_5"
        label   "OUT"
        hidewhentab "{ flamefunc == 0 } { h_valid == 0 }"

        parm {
            name    "outdisable"
            label   "disable"
            type    toggle
            invisible
            default { "1" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "outisvalidfile"
            label   "is valid file"
            type    toggle
            invisible
            default { "0" }
            disablewhen "{ outdisable == 1 }"
            parmtag { "script_callback_language" "python" }
        }
        groupsimple {
            name    "f_outmain"
            label   "OUT"
            grouptag { "group_type" "simple" }

            parm {
                name    "outpath"
                label   "OUT flame"
                type    file
                default { "" }
                help    "Select a file name to save your Flame into. If the selected file does not exist, it will be created."
                parmtag { "filechooser_pattern" "*.flame" }
                parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_init_presets_OUT_PRESETS(), kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "outname"
                label   "Flame name"
                type    string
                default { "" }
                help    "Save this Flame with this name.\\nThis is the name the Flame will have inside the XML file.\\n\\nIf no name is provided, a default name composed of today's date and current time will be used instead."
                parmtag { "script_action" "kwargs['node'].hdaModule().flam3.out_flame_utils(kwargs).out_XML()" }
                parmtag { "script_action_help" "[LMB] to save this Flame inside the selected OUT file, if any. If the file doesn't exit yet it will create it. If the file contain already some Flames, it will append it. [CTRL+LMB] to erase the content of the file and save only the current Flame in it. [SHIFT+LMB] if not a valid filepath is present already it will open a file chooser, otherwise it will open the file explorer to the file location. [ALT+LMB] to save this Flame into the Clipboard. " }
                parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_WhiteStarSVG.svg" }
                parmtag { "script_callback" "hou.phm().flam3.out_flame_utils(kwargs).out_auto_add_iter_num_to_prm(), kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "outpresets"
                label   "OUT file contents"
                type    string
                default { "-1" }
                help    "This menu is only for informational purposes.\\nIt will show the Flame presets contained in the selected output file, if any are present. Once you add a new Flame to it, this menu will update too. It will always be set to the last Flame name you saved.\\n\\nIt will also print quick informations ( in the status bar and as a flash message in the network editor)\\nabout the Flame preset when one is selected.\\n\\nQuick infos are:\\n- Flame preset name ( only in the status bar )\\n- FF: when finalXform(FF) is being used\\n- RIP: when Remove Invalid Points(RIP) is being used ( only in the status bar )\\n- F3C: when Flam3 Compatibility is being used ( only in the status bar )\\n- XF: Number of iterators/xforms being used\\n- Palette: number of colors in the palette\\n- HSV: when HSV color correction is being used\\n- HSV values ( only in the status bar )\\n- Basis: palette lookup sample interpolation method being used"
                menu {
                    [ "menu = hou.phm().flam3.out_flame_utils(kwargs).menu_out_contents_presets()" ]
                    [ "return menu" ]
                    language python
                }
                parmtag { "script_action" "kwargs['node'].hdaModule().flam3.out_flame_utils(kwargs).out_presets_copy_menu_label_callback()" }
                parmtag { "script_action_help" "[LMB] to copy the currently selected OUT Flame preset' name into the OUT Flame name parameter string field. [SHIFT+LMB] to print quick informations message about the selected OUT Flame preset. [CTRL+LMB] to display the Flame name informations/tips. [ALT+LMB] to copy the selected OUT Flame preset into the Clipboard." }
                parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarBlueToolSVG.svg" }
                parmtag { "script_callback" "hou.phm().flam3.out_flame_utils(kwargs).out_to_flam3h_quick(), kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "outmsg"
                label   "outmsg"
                type    label
                default { "" }
                parmtag { "sidefx::look" "block" }
            }
        }

        groupcollapsible {
            name    "f_outoptions"
            label   "OUT options"
            grouptag { "group_type" "collapsible" }

            parm {
                name    "outpalette"
                label   "palette HSV"
                type    toggle
                default { "0" }
                help    "OFF by default.\\nWhen saving out a Flame, FLAM3H™ by default uses the non-color-corrected palette and save the HSV values along with it if used ( different from default values ).\\n\\nIf switched ON,\\nthis option will allow you to save the color-corrected HSV palette instead.\\n\\nThis option will clamp the palette colors on save to 0-255 and you should use this only when you want to export the desired colors to be loaded inside Fratorium or Apophysis or other fractal flame editors out there."
                parmtag { "script_callback" "kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "out_f3h_affine"
                label   "F3H affine style"
                type    toggle
                default { "1" }
                help    "ON by default.\\nSave the Flame out with also the F3H affine style format.\\n\\nF3H affine style format are useful when you rotate iterators using the Rot angle parameter and you still want to reload the Flame using the Rotation value instead of the affine transformed by that Rotation whitch can lead to values that are hard to edit once loaded back into FLAM3H™.\\n\\nNOTE:\\nWhen this toggle is ON, both affine and F3H affine style formats are saved with the Flame preset so that you can still load the saved Flame into other applications."
                parmtag { "script_callback" "kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "out_in_flame_name"
                label   "Flame name inherit on Load"
                type    toggle
                default { "0" }
                help    "OFF by default.\\nCause the OUT Flame name parameter to automatically be set\\nto the name of the loaded IN flame preset.\\n\\nIt will work for Flame presets loaded from a disk file or from the Clipboard."
                parmtag { "script_callback" "hou.phm().flam3.out_flame_utils(kwargs).out_flame_name_inherit_on_load(), kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "outfractoriumprm"
                label   "use Fractorium paramtetrics"
                type    toggle
                default { "1" }
                help    "ON by default.\\nTo export the parameter names for parametric variations to the one that Fractorium uses.\\n\\nThis is only useful if you have used the Oscope and/or the Mobius variations and you would like to load the saved Flame into Fractorium as it uses diferent parametric paramter's names for these.\\n\\nNOTE:\\nFor a Flame to be loaded inside Apophysis check this toggle OFF when saving it out if it is using the Oscope and/or the Mobius variations."
                parmtag { "script_callback" "kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "autoadditer"
                label   "add iterations to Flame name"
                type    toggle
                default { "1" }
                help    "ON by default.\\nIt will automatically append the iteration number to the flame name you enter.\\nOnce you type in a flame name, changing the iteration number will update the flame name too.\\n\\nIt will also autocorrect the flame name string based on internally defined rules.\\n\\nNOTE:\\nThis option is not needed when in GPU mode."
                disablewhen "{ gpu == 1 }"
                parmtag { "script_callback" "hou.phm().flam3.out_flame_utils(kwargs).out_auto_change_iter_num_to_prm(), kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
        }

        groupcollapsible {
            name    "f_outrenderproperties"
            label   "OUT render properties"
            parmtag { "group_default" "1" }
            grouptag { "group_type" "collapsible" }

            parm {
                name    "outedit"
                label   "edit render properties"
                type    toggle
                default { "0" }
                help    "OFF by default.\\nAllow the editing of the Flame render properties.\\n\\nThese properties will be stored into the preset file when you save this Flame out from FLAM3H™.\\n\\nThey will control how the saved fractal Flame will render inside other applications like Fractorium and Apophysis. They are their renderer settings, and they will be exported into the XML file.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
                parmtag { "script_action" "kwargs['node'].hdaModule().flam3.out_flame_utils(kwargs).reset_OUT_kwargs()" }
                parmtag { "script_action_help" "[LMB] to reset all the OUT Render properties. [SHIFT+LMB] to reset only the OUT Camera SENSOR properties. [CTRL+LMB] to reset only the OUT RENDER settings properties. Additionally: [ALT+LMB] to copy all the render properties of a Flame preset from the Clipboard into here (SENSOR, RENDER and CC CURVES settings)." }
                parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarWhiteKwargsSVG.svg" }
                parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_toggle_off(\"outsensor\"), kwargs['parm'].deleteAllKeyframes()" }
                parmtag { "script_callback_language" "python" }
            }
            groupsimple {
                name    "f_outrendersensor"
                label   "OUT sensor settings"
                disablewhentab "{ outedit == 0 }"
                grouptag { "group_type" "simple" }

                parm {
                    name    "out_sensorviz_disabled"
                    label   "ENTER sensor viz"
                    type    button
                    default { "0" }
                    help    "ENTER sensor viz mode.\\n\\nAll the render settings required by third-party programs such as Apophysis and Fractorium are stored together with the fractal flames when they are saved from FLAM3H™.\\n\\nA portion of the render parameters deal with the camera and how the fractal flame you just saved is framed. The FLAM3H™ camera sensor will precisely display the image framing.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
                    hidewhen "{ outsensor == 1 }"
                    parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_TagORedSVG_disabled.svg" }
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_outsensor_toggle(), kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "out_sensorviz"
                    label   "EXIT sensor viz"
                    type    button
                    default { "0" }
                    help    "EXIT sensor viz mode. Camera sensor update ON.\\n\\nAll the render settings required by third-party programs such as Apophysis and Fractorium are stored together with the fractal flames when they are saved from FLAM3H™.\\n\\nA portion of the render parameters deal with the camera and how the fractal flame you just saved is framed. The FLAM3H™ camera sensor will precisely display the image framing.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
                    hidewhen "{ outsensor == 0 } { outsensorupdate == 0 }"
                    parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_TagORedSVG.svg" }
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_outsensor_toggle(), kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "out_sensorviz_off"
                    label   "EXIT sensor viz"
                    type    button
                    default { "0" }
                    help    "EXIT sensor viz mode. Camera sensor update OFF.\\n\\nAll the render settings required by third-party programs such as Apophysis and Fractorium are stored together with the fractal flames when they are saved from FLAM3H™.\\n\\nA portion of the render parameters deal with the camera and how the fractal flame you just saved is framed. The FLAM3H™ camera sensor will precisely display the image framing.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
                    hidewhen "{ outsensor == 0 } { outsensorupdate == 1 }"
                    parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_TagORedOffSVG.svg" }
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).flam3h_outsensor_toggle(), kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "outres"
                    label   "resolution"
                    type    intvector2
                    joinnext
                    size    2
                    default { "1024" "1024" }
                    help    "The image resolution.\\n\\nThis parameter will be saved into the Flame file and used by a third-party application renderer.\\nFractorium being the preferred one followed by Apophysis and others."
                    disablewhen "{ outedit == 0 }"
                    range   { 256! 4096 }
                    parmtag { "cook_dependent" "1" }
                    parmtag { "script_action_help" "The image resolution." }
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).util_set_front_viewer(False)" }
                    parmtag { "script_callback_language" "python" }
                    parmtag { "spare_category" "View" }
                }
                parm {
                    name    "outrespresets"
                    label   "OUT Res presets"
                    type    string
                    nolabel
                    joinnext
                    default { "-1" }
                    menumini {
                        [ "menu = hou.phm().flam3.out_flame_utils(kwargs).menu_sensor_resolution()" ]
                        [ "return menu" ]
                        language python
                    }
                    parmtag { "script_callback" "hou.phm().flam3.out_flame_utils(kwargs).menu_sensor_resolution_set(False), kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "outcprendervals"
                    label   "Copy ALL IN Flame preset render properties"
                    type    button
                    nolabel
                    default { "0" }
                    help    "[LMB] to copy ALL the currently loaded IN Flame preset render properties (SENSOR, RENDER and CC CURVES settings) into here, the OUT render properties.\\nWhen you load a Flame preset from a file or from the Clipboard, this icon will become available.\\n\\nAll the render properties of a Flame preset loaded from the clipboard will be automatically copied into here, the OUT render properties, on load.\\n\\nNOTE:\\nYou can load all the render properties of a Flame preset stored in the Clipboard into here\\nusing [ALT+LMB] from the above \"edit render properties\" toggle parameter kwargs star icon. "
                    disablewhen "{ inisvalidpreset == 0 }"
                    parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_StarSwapRedCopyPasteInfosSVG.svg" }
                    parmtag { "script_callback" "hou.phm().flam3.in_flame_utils.in_copy_render_all_stats_msg(kwargs, None, False, True), kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "outcenter"
                    label   "center"
                    type    vector2
                    size    2
                    default { "0" "0" }
                    help    "The center of the frame.\\nOffsets the camera in fractal space (panning).\\n\\nThis parameter will be saved into the Flame file and used by a third-party application renderer.\\nFractorium being the preferred one followed by Apophysis and others."
                    disablewhen "{ outedit == 0 }"
                    range   { -5 5 }
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).util_set_front_viewer(False)" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "outrotate"
                    label   "rotate"
                    type    float
                    default { "0" }
                    help    "The camera rotation.\\n\\nThis parameter will be saved into the Flame file and used by a third-party application renderer.\\nFractorium being the preferred one followed by Apophysis and others."
                    disablewhen "{ outedit == 0 }"
                    range   { -360 360 }
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).util_set_front_viewer(False)" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "outscale"
                    label   "scale"
                    type    float
                    default { "400" }
                    help    "Size of the lens.\\nBecause the quality won't be raised once loaded into third-party programs such as Fractorium or Apophysis, you will need to manually alter it from within the host program, making this XML key an affordable way to achieve zoom.\\n\\nThis parameter will be saved into the Flame file and used by a third-party application renderer.\\nFractorium being the preferred one followed by Apophysis and others."
                    disablewhen "{ outedit == 0 }"
                    range   { 16! 2048 }
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).util_set_front_viewer(False)" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "outsensorupdate"
                    label   "update sensor"
                    type    toggle
                    default { "1" }
                    help    "ON by default.\\nEvery change to the camera sensor parameters will update the sensor viewport viz.\\n\\nTurn this OFF to disable any sensor viewport's updates."
                    disablewhen "{ outsensor == 0 }"
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).util_set_front_viewer(False), kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
            }

            groupsimple {
                name    "f_outrendersettings"
                label   "OUT renderer settings"
                disablewhentab "{ outedit == 0 }"
                grouptag { "group_type" "simple" }

                parm {
                    name    "outquality"
                    label   "quality"
                    type    integer
                    default { "1000" }
                    help    "The render quality is the same as the \"density\" value in FLAM3H™.\\n\\nThis parameter will be saved into the Flame file and used by a third-party application renderer.\\nFractorium being the preferred one followed by Apophysis and others."
                    disablewhen "{ outedit == 0 }"
                    range   { 64! 2048 }
                    parmtag { "script_action_help" "The render quality. Think of this as how many points are used inside Fractorium to render the final image. The more the more cleaner the final image." }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "outbrightness"
                    label   "brightness"
                    type    float
                    default { "3" }
                    help    "Shifts the overall lightness or darkness of the image.\\n\\nThis parameter will be saved into the Flame file and used by a third-party application renderer.\\nFractorium being the preferred one followed by Apophysis and others."
                    disablewhen "{ outedit == 0 }"
                    range   { 1! 16 }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "outgamma"
                    label   "gamma"
                    type    float
                    default { "2.5" }
                    help    "Adjusts midtones without heavily changing black or white.\\n\\nThis parameter will be saved into the Flame file and used by a third-party application renderer.\\nFractorium being the preferred one followed by Apophysis and others."
                    disablewhen "{ outedit == 0 }"
                    range   { 1! 10 }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "outhighlight"
                    label   "highlight power"
                    type    float
                    default { "5" }
                    help    "Controls how intense the brightest areas appear.\\n\\nThis parameter will be saved into the Flame file and used by a third-party application renderer.\\nFractorium being the preferred one followed by Apophysis and others."
                    disablewhen "{ outedit == 0 }"
                    range   { 0! 5 }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "outk2"
                    label   "logscale K2"
                    type    float
                    default { "0" }
                    help    "Uses a logarithmic curve to compress or expand midrange values.\\n\\nThis parameter will be saved into the Flame file and used by a third-party application renderer.\\nFractorium being the preferred one followed by Apophysis and others."
                    disablewhen "{ outedit == 0 }"
                    range   { 0! 1 }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "outvibrancy"
                    label   "vibrancy"
                    type    float
                    default { "0.3333" }
                    help    "Boosts muted colors while keeping vivid tones natural.\\n\\nThis parameter will be saved into the Flame file and used by a third-party application renderer.\\nFractorium being the preferred one followed by Apophysis and others."
                    disablewhen "{ outedit == 0 }"
                    range   { 0! 1 }
                    parmtag { "script_callback_language" "python" }
                }
            }

            groupcollapsible {
                name    "f_outrendercurves"
                label   "OUT renderer color correction curves"
                disablewhentab "{ outedit == 0 }"
                parmtag { "group_default" "0" }
                grouptag { "group_type" "collapsible" }
                parmtag { "sidefx::header_toggle" "outccdefault" }

                parm {
                    name    "outccdefault"
                    label   "Default toggle"
                    type    toggle
                    nolabel
                    default { "0" }
                    help    "This toggle indicate when a color correction is active.\\nIt will be OFF when the color correction curves values are at their defaults."
                    disablewhen "{ outdisable == 1 }"
                    parmtag { "script_callback" "hou.phm().flam3.out_flame_utils.out_render_curves_compare_and_set_toggle(kwargs['node']), kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "empty_out_01"
                    label   "empty"
                    type    geometrydata
                    nolabel
                    joinnext
                    default { "0" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "icon_f3h_cc_defaults_copy"
                    label   "CC CURVES: Defaults"
                    type    button
                    nolabel
                    joinnext
                    default { "0" }
                    help    "CC Curves at their defaults.\\n\\n[LMB] to copy all the color correction curves data from the currently loaded IN Flame preset.\\nIf the loaded IN Flame preset have its color correction curves data at default values, the copy will be skipped.\\n\\nThese color correction curves data can not be edited.\\nThe data is stored here from the loaded Flame preset, and it will be saved into the file when you save the Flame preset out from FLAM3H™ so to keep and preserve the original color correction data intact."
                    hidewhen "{ outccdefault == 1 }"
                    parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarWhiteSVG.svg" }
                    parmtag { "script_callback" "hou.phm().flam3.in_flame_utils.in_copy_cc_curves_stats_msg(kwargs), kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "icon_f3h_cc_modified_reset"
                    label   "CC CURVES: Modified"
                    type    button
                    nolabel
                    joinnext
                    default { "0" }
                    help    "CC Curves modified.\\n\\n[LMB] to reset all the color correction curves to their defaults (no color correction).\\n\\nThese color correction curves data can not be edited.\\nThe data is stored here from the loaded Flame preset, and it will be saved into the file when you save the Flame preset out from FLAM3H™ so to keep and preserve the original color correction data intact."
                    hidewhen "{ outccdefault == 0 }"
                    parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarRedSVG.svg" }
                    parmtag { "script_callback" "hou.phm().flam3.out_flame_utils.out_render_curves_set_and_retrieve_defaults(kwargs['node']), kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "label_outccdefault"
                    label   "Heading"
                    type    label
                    default { "Defaults" }
                    parmtag { "sidefx::look" "heading" }
                }
                parm {
                    name    "empty_out_02"
                    label   "empty"
                    type    geometrydata
                    invisible
                    nolabel
                    default { "0" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "icon_f3h_cc_curves"
                    label   "Curves All"
                    type    button
                    invisible
                    nolabel
                    joinnext
                    default { "0" }
                    help    "Color correction: CURVES (All)\\n\\nThis is data coming from Fractorium's color correction curves when the loaded Flame preset uses it.\\nIf not used or found, default values (no color correction) will be used instead.\\n\\nThis parameter data will be saved into the Flame file and used by a third-party application renderer.\\nFractorium being the preferred one followed by Apophysis and others."
                    disablewhen "{ outdisable == 1 }"
                    parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarBlueSVG.svg" }
                    parmtag { "script_callback" "" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "outcurvesval"
                    label   "curves"
                    type    string
                    invisible
                    nolabel
                    default { "0 0 1 0.25 0.25 1 0.5 0.5 1 0.75 0.75 1 0 0 1 0.25 0.25 1 0.5 0.5 1 0.75 0.75 1 0 0 1 0.25 0.25 1 0.5 0.5 1 0.75 0.75 1 0 0 1 0.25 0.25 1 0.5 0.5 1 0.75 0.75 1" }
                    parmtag { "script_callback" "hou.phm().flam3.out_flame_utils.out_render_curves_retrive_data(kwargs['node'])" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "empty_out_03"
                    label   "empty"
                    type    geometrydata
                    nolabel
                    default { "0" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "icon_f3h_cc_overall"
                    label   "Curve Overall"
                    type    button
                    nolabel
                    joinnext
                    default { "0" }
                    help    "Color correction: OVERALL (Luminance)\\n\\nThis is data coming from Fractorium's color correction curves when the loaded Flame preset uses it.\\nIf not used or found, default values (no color correction) will be used instead.\\n\\nThis parameter data will be saved into the Flame file and used by a third-party application renderer.\\nFractorium being the preferred one followed by Apophysis and others."
                    disablewhen "{ outdisable == 1 }"
                    parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarBlueSVG.svg" }
                    parmtag { "script_callback" "" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "outcurveoverallval"
                    label   "overall"
                    type    string
                    nolabel
                    default { "0 0 0.25 0.25 0.5 0.5 0.75 0.75 1 1" }
                    parmtag { "script_callback" "hou.phm().flam3.out_flame_utils.out_render_curves_retrive_data(kwargs['node'])" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "empty_out_04"
                    label   "empty"
                    type    geometrydata
                    nolabel
                    default { "0" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "icon_f3h_cc_red"
                    label   "Curve Red"
                    type    button
                    nolabel
                    joinnext
                    default { "0" }
                    help    "Color correction: RED\\n\\nThis is data coming from Fractorium's color correction curves when the loaded Flame preset uses it.\\nIf not used or found, default values (no color correction) will be used instead.\\n\\nThis parameter data will be saved into the Flame file and used by a third-party application renderer.\\nFractorium being the preferred one followed by Apophysis and others."
                    disablewhen "{ outdisable == 1 }"
                    parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarBlueSVG.svg" }
                    parmtag { "script_callback" "" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "outcurveredval"
                    label   "red"
                    type    string
                    nolabel
                    default { "0 0 0.25 0.25 0.5 0.5 0.75 0.75 1 1" }
                    parmtag { "script_callback" "hou.phm().flam3.out_flame_utils.out_render_curves_retrive_data(kwargs['node'])" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "icon_f3h_cc_green"
                    label   "Curve Green"
                    type    button
                    nolabel
                    joinnext
                    default { "0" }
                    help    "Color correction: GREEN\\n\\nThis is data coming from Fractorium's color correction curves when the loaded Flame preset uses it.\\nIf not used or found, default values (no color correction) will be used instead.\\n\\nThis parameter data will be saved into the Flame file and used by a third-party application renderer.\\nFractorium being the preferred one followed by Apophysis and others."
                    disablewhen "{ outdisable == 1 }"
                    parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarBlueSVG.svg" }
                    parmtag { "script_callback" "" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "outcurvegreenval"
                    label   "green"
                    type    string
                    nolabel
                    default { "0 0 0.25 0.25 0.5 0.5 0.75 0.75 1 1" }
                    parmtag { "script_callback" "hou.phm().flam3.out_flame_utils.out_render_curves_retrive_data(kwargs['node'])" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "icon_f3h_cc_blue"
                    label   "Curve Blue"
                    type    button
                    nolabel
                    joinnext
                    default { "0" }
                    help    "Color correction: BLUE\\n\\nThis is data coming from Fractorium's color correction curves when the loaded Flame preset uses it.\\nIf not used or found, default values (no color correction) will be used instead.\\n\\nThis parameter data will be saved into the Flame file and used by a third-party application renderer.\\nFractorium being the preferred one followed by Apophysis and others."
                    disablewhen "{ outdisable == 1 }"
                    parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarBlueSVG.svg" }
                    parmtag { "script_callback" "" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "outcurveblueval"
                    label   "blue"
                    type    string
                    nolabel
                    default { "0 0 0.25 0.25 0.5 0.5 0.75 0.75 1 1" }
                    parmtag { "script_callback" "hou.phm().flam3.out_flame_utils.out_render_curves_retrive_data(kwargs['node'])" }
                    parmtag { "script_callback_language" "python" }
                }
            }

        }

    }

    group {
        name    "f_flam3h_6"
        label   "prefs"
        hidewhentab "{ flamefunc == 0 } { h_valid == 0 }"

        groupcollapsible {
            name    "f_prefs"
            label   "FLAM3H™"
            parmtag { "group_default" "1" }
            grouptag { "group_type" "collapsible" }

            parm {
                name    "prefsdisable"
                label   "disable"
                type    toggle
                invisible
                default { "1" }
                parmtag { "script_callback_language" "python" }
            }
            groupsimple {
                name    "f_prefsgpu"
                label   "prefs GPU"
                grouptag { "group_type" "simple" }

                parm {
                    name    "gpu"
                    label   "GPU"
                    type    toggle
                    default { "1" }
                    help    "ON by default.\\n\\nRun the algorithm entirely on the GPU device.\\n\\nThis can be hundreds of times faster compared to the CPU(CVEX) implementation\\ndepending on the system' GPU device being used.\\n\\nNOTE:\\nwhen switching this toggle OFF for the very first time,\\nHoudini will compile all the FLAM3H™ CPU(CVEX) nodes.\\nDepending on your PC configuration it can take up to 1(one) minute.\\nIt is a one time compile process.\\n\\nTIPS:\\nWhen in GPU mode, having the SYS Tab RIP(Remove Invalid Points) toggle ON will slow down\\nas it will be taxing to cleanup the incoming point cloud from the GPU nodes.\\nKeep the RIP(Remove Invalid Points) toggle OFF while editing your fractal Flames in GPU mode\\nto go full speed and Activate it only if/when needed:\\n(e.g. before any rendering or to check the final result from time to time if any iterators' opacity is 0(Zero) or NaN values are present)."
                    parmtag { "script_callback" "hou.phm().flam3.out_flame_utils(kwargs).out_auto_change_iter_num_to_prm(), kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "gpu_iter"
                    label   "iterations"
                    type    ordinal
                    default { "1024" }
                    help    "1024 by default.\\n\\nWhen GPU is ON/Active,\\nrun the algorithm with this number of iterations.\\n\\nThe default value is: 1024 (hence the bookmark icon),\\nand it should be good for almost all cases;\\nhowever you can change this value to be lower and/or higher if you desire."
                    disablewhen "{ gpu == 0 }"
                    menu usetokenvalue {
                        "128"   "128                          "
                        "256"   "256"
                        "512"   "512"
                        "1024"  "![opdef:/alexnardini::Sop/FLAM3H?icon_optionOCLSVG.svg]1024"
                        "2048"  "2048"
                        "4096"  "4096"
                    }
                    parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_general_utils(kwargs).reset_parm((1024,))" }
                    parmtag { "script_action_help" "[LMB] to reset the GPU iterations to the default: 1024" }
                    parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionOCLSVG.svg" }
                    parmtag { "script_callback" "kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
            }

            groupcollapsible {
                name    "f_prefsgpu_compiler"
                label   "prefs GPU compiler"
                invisibletab
                grouptag { "group_type" "collapsible" }

                parm {
                    name    "use_cl_fast"
                    label   "cl fast relaxed math"
                    type    toggle
                    default { "1" }
                    help    "ON by default.\\n\\nEnable -cl-fast-relaxed-math compiler flag.\\nLet the compiler optimize aggressively."
                    disablewhen "{ gpu == 0 }"
                    parmtag { "script_callback" "" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "sepparm4"
                    label   "Spacer"
                    type    separator
                    default { "" }
                    parmtag { "sidefx::layout_height" "small" }
                    parmtag { "sidefx::look" "blank" }
                }
                parm {
                    name    "use_fma"
                    label   "fma"
                    type    toggle
                    default { "1" }
                    help    "ON by default.\\n\\nEnable fused multiply-add if desired."
                    disablewhen "{ gpu == 0 }"
                    parmtag { "script_callback" "" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "use_native"
                    label   "native math"
                    type    toggle
                    default { "1" }
                    help    "ON by default.\\n\\nEnable faster native OpenCL math functions (native_*).\\nThese may reduce precision and produce device-dependent results."
                    disablewhen "{ gpu == 0 }"
                    parmtag { "script_callback" "" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "use_rng_x128"
                    label   "rng xoroshiro128+"
                    type    toggle
                    default { "1" }
                    help    "ON by default.\\n\\nEnable RNG (Random Number Generator) Xoroshiro128+.\\nProduces different random sequences with better randomness and longer period.\\n\\nWhen OFF it will use the older MWC64X."
                    disablewhen "{ gpu == 0 }"
                    parmtag { "export_disable" "1" }
                    parmtag { "script_callback" "" }
                    parmtag { "script_callback_language" "python" }
                }
            }

            groupsimple {
                name    "f_prefsgeneral"
                label   "prefs general"
                grouptag { "group_type" "simple" }

                parm {
                    name    "reframeval"
                    label   "viewport frame size"
                    type    float
                    invisible
                    default { "1" }
                    help    "The bounding box size that will be viewport framed when the SYS Tab frameview icon is clicked.\\n\\nA value of 1 should work well in every situation, but you can increase it if you'd like.\\n\\nConsider this as the size of a box at the ZERO world that, upon clicking the SYS Tab frame viewport icon, will be center framed in the viewport.\\nOnce this value is changed, Click the SYS Tab Frame viewport to see the new framing."
                    range   { 1! 2 }
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).util_viewport_bbox_frame()" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "paletteplus"
                    label   "palette 256+"
                    type    toggle
                    default { "1" }
                    help    "ON by default.\\nIt will allow the OUT Flame to be saved with more than 256 color keys assuming you created a Palette with this many colors otherwise it will always save the Flame using the standard 256 color keys.\\n\\nIf the Palette color keys are less than 256, it will always sample the Palette at 256 when saving out the Flame preset.\\nThe maximun Palette color keys you can use are 1024, if you create a Palette with more, it will be sampled at 1024 colors.\\n\\nNOTE:\\nIf you are planning to load the saved Flame inside Apophysis, remember that it will fail if the Flame preset you are trying to load posses a Palette with more than 256 color keys."
                    parmtag { "script_callback" "hou.phm().flam3.out_flame_utils(kwargs).out_palette_256_plus_check(), kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "solo_follow"
                    label   "SOLO follow"
                    type    toggle
                    default { "1" }
                    help    "ON by default.\\nWhen any iterator has its xform handle in SOLO mode already, it causes the iterator that is selected or picked from the SYS tab's select iterator mini-menu to be automatically configured to be in SOLO mode.\\nThis enables you to swiftly go over each one automatically.\\n\\nTo prevent the selected iterator from being in SOLO mode while being selected, turn this OFF."
                    parmtag { "script_callback" "kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "flashmsg"
                    label   "flash messages"
                    type    toggle
                    default { "1" }
                    help    "ON by default.\\nCauses a message to appear briefly in the upper left corner of the network editor, then fade away.\\n\\nCopy/Paste iterators and FF data uses flash messages, as well as some other features."
                    parmtag { "script_callback" "kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "iterclr"
                    label   "iterative color attribute"
                    type    toggle
                    default { "0" }
                    help    "OFF by default.\\nOutput the iterative color float point attribute @clr used internally by FLAM3H™\\nto map the palette colors to the points.\\n\\nThe attribute values are computed inside the chaos game\\nand can be usefull to post process the output point cloud in many ways.\\n\\nIt is dependent of each iterator shader location and speed parameters values\\nalong with the number of iterations being used. "
                    parmtag { "script_callback" "kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
            }

            groupsimple {
                name    "f_prefsui"
                label   "prefs UI"
                grouptag { "group_type" "simple" }

                parm {
                    name    "enumeratemenu"
                    label   "enumerate presets menus"
                    type    toggle
                    default { "1" }
                    help    "ON by default.\\nCauses the presets menus inside the CP, IN and OUT tab to be enumerated.\\nThis make it easy to remember a particular preset you liked while trying out others inside the loaded library file.\\n\\nTurn this OFF to only display the raw preset names.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).menus_refresh_enum_prefs(), kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "itericons"
                    label   "iterator menus bookmark icons"
                    type    toggle
                    invisible
                    default { "0" }
                    help    "OFF by default.\\nCauses the variation menus inside each iterator to have a bookmark icon (FLAME and FF tab).\\n\\nThis is a dynamic mode that will change each variation's menu based of the value of their weight hence it will take a hit on the UI performance.\\n\\nWhen you turn this toggle back OFF,\\nHoudini will revert the density value to its default (500k points) as a way to reduce the waiting time since a re-compute of the fractal Flame is triggered."
                    disablewhen "{ prefsdisable == 1 }"
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_iterator_utils(kwargs).refresh_iterator_vars_menu(), kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
            }

            groupcollapsible {
                name    "f_prefscvex"
                label   "prefs cvex precision"
                invisibletab
                grouptag { "group_type" "collapsible" }

                parm {
                    name    "vex_precision"
                    label   "modes"
                    type    string
                    default { "32" }
                    help    "Switch between the default Single Precision ( 32-bit ) or Double Precision ( 64-bit ).\\n\\n64-bit double precision will be really, really slow. I repeat: really, really slow.\\nAlways use the default 32-bit unless you notice some major artifacts and you truly love the fractal flame you are working on.\\n\\nWhen switching to Double Precision ( 64-bit ) for the first time, it will Re-Compile all FLAM3H CVEX nodes. Depending on your PC configuration it can take anywhere between 30s and 1 minute.\\nIt is a one time compile process."
                    menu {
                        "32"    "![opdef:/alexnardini::Sop/FLAM3H?icon_optionStarWhiteSVG.svg]32-bit (SP)       "
                        "64"    "64-bit (DP)"
                    }
                    parmtag { "autoscope" "0000000000000000" }
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_scripts(kwargs).flam3h_check_first_node_instance_prefs_cvex_precision_msg(), kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
            }

            groupsimple {
                name    "f_prefsxaos"
                label   "prefs xaos:"
                grouptag { "group_type" "simple" }

                parm {
                    name    "xm"
                    label   "mode"
                    type    ordinal
                    default { "0" }
                    help    "Set the XAOS mode to use.\\nOnce changed, FLAM3H™ will reset all iterators' xaos weights to reflect the new mode.\\n\\nWhen saving out Flame files, xaos FROM mode will internally be converted into xaos TO on save and reloaded as xaos TO.\\n\\nxaos TO (default):\\nSpecifies how likely an iterator/xform is to be chosen based on the previous iterator/xform that was chosen.\\n\\nxaos FROM:\\nSpecifies the probability modifier of the next chosen iterator/xform based on the currently chosen one."
                    menu usetokenvalue {
                        "0" "![opdef:/alexnardini::Sop/FLAM3H?icon_optionStarWhiteSVG.svg]xaos TO       "
                        "1" "xaos FROM"
                    }
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_iterator_utils(kwargs).flam3h_xaos_convert(), kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
            }

            groupsimple {
                name    "f_prefsdensity"
                label   "prefs density"
                grouptag { "group_type" "simple" }

                parm {
                    name    "ptcount"
                    label   "density"
                    type    integer
                    default { "500000" }
                    help    "Set a custom density value for the fractal Flame.\\n\\nIf the global tab's density menu entries do not have whant you need,\\nyou can set a custom density value using this parameter.\\n\\nNOTE:\\nThis is the only place where you are allowed to animate the density value."
                    hidewhen "{ flamefunc == 0 }"
                    range   { 1! 1e+06 }
                    parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_iterator_utils(kwargs).menu_global_density_set_default()" }
                    parmtag { "script_action_help" "[LMB] to reset density to its default: 500k(thousands) points. This is what should be used while editing fractal Flames most of the time. Additionally: [SHIFT+LMB] set density to: 300k(thousands). [CTRL+LMB] set density to: 200k(thousands). [ALT+LMB] set density to: 100k(thousands)" }
                    parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarWhiteToolSVG.svg" }
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_iterator_utils.flam3h_on_loaded_set_density_menu(kwargs['node'])" }
                    parmtag { "script_callback_language" "python" }
                }
            }

            groupcollapsible {
                name    "f_prefscamera"
                label   "prefs camera"
                grouptag { "group_type" "collapsible" }

                parm {
                    name    "camhandle"
                    label   "handle"
                    type    toggle
                    default { "0" }
                    help    "OFF by default.\\nDisplay the viewport camera handle to help frame/center your fractal flame.\\n\\nTurn this off when rendering.\\n\\nNote:\\nThe handles are properly scaled and visible only when looking through a perspective type of camera,\\nnot when looking through an orthogonal type of camera."
                    parmtag { "script_callback" "kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "camcull"
                    label   "camera cull"
                    type    toggle
                    default { "0" }
                    help    "OFF by default.\\nEnable culling based on camera view."
                    parmtag { "script_callback" "kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "fcam"
                    label   "cam"
                    type    oppath
                    default { "" }
                    help    "Camera to use for either the handles or the culling"
                    disablewhen "{ camcull == 0 camhandle == 0 }"
                    parmtag { "opfilter" "!!OBJ/CAMERA!!" }
                    parmtag { "oprelative" "." }
                    parmtag { "script_callback" "kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "cullamount"
                    label   "amount"
                    type    float
                    default { "0.99" }
                    help    "Camera cull amount"
                    disablewhen "{ camcull == 0 }"
                    range   { 0 1 }
                    parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_general_utils(kwargs).reset_parm((0.99,))" }
                    parmtag { "script_action_help" "[LMB] to reset the camera cull amount to: 0.99" }
                    parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarWhiteSVG.svg" }
                    parmtag { "script_callback_language" "python" }
                }
            }

            groupsimple {
                name    "f_prefsviewport"
                label   "prefs viewport"
                grouptag { "group_type" "simple" }

                parm {
                    name    "setdark"
                    label   "dark"
                    type    toggle
                    default { "0" }
                    help    "OFF by default.\\nSet dark viewport color scheme"
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).colorSchemeDark(), kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "sepparm2"
                    label   "Spacer"
                    type    separator
                    default { "" }
                    parmtag { "sidefx::layout_height" "medium" }
                    parmtag { "sidefx::look" "blank" }
                }
                parm {
                    name    "vptype"
                    label   "display"
                    type    ordinal
                    default { "0" }
                    help    "Types of Viewport Point Display types.\\n\\nAt the moment of this writing (up to H21),\\nIt is suggested to go to the Houdini: Edit->Preferences->3Dviewport and set the Renderer to OpenGL as it provide a better points visualization in the viewport when millions of them are displayed and/or their viewport point size is smaller than 1(one).\\n\\nChanging the viewer renderer will require a restart of Houdini."
                    menu {
                        "0" "![opdef:/alexnardini::Sop/FLAM3H?icon_optionStarWhiteSVG.svg]Points          "
                        "1" "Pixels"
                    }
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).viewportParticleDisplay(), kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "vpptsize"
                    label   "size"
                    type    float
                    default { "1" }
                    help    "If display type is set to Points, this will set the size of those points in the viewport.\\n\\nAt the moment of this writing (up to H21),\\nIt is suggested to go to the Houdini: Edit->Preferences->3Dviewport and set the Renderer to OpenGL as it provide a better points visualization in the viewport when millions of them are displayed and/or their viewport point size is smaller than 1(one).\\n\\nChanging the viewer renderer will require a restart of Houdini."
                    disablewhen "{ vptype == 1 }"
                    range   { 0.1! 2 }
                    parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_general_utils(kwargs).viewportParticleSize(1.0)" }
                    parmtag { "script_action_help" "[LMB] to reset this parameter to a value of: 1.0" }
                    parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarWhiteSVG.svg" }
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).viewportParticleSize(), kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "sepparm3"
                    label   "Spacer"
                    type    separator
                    default { "" }
                    parmtag { "sidefx::layout_height" "medium" }
                    parmtag { "sidefx::look" "blank" }
                }
                parm {
                    name    "vpww"
                    label   "wire width"
                    type    float
                    default { "3" }
                    help    "When the SYS -> \"xforms handles VIZ\" is ON, this parameter will set the wire curves thickness for the viewport display. A value of 3.0 is generally good."
                    disablewhen "{ vizhandles == 0 } { outsensor == 1 } { ptcount > 5000000 }"
                    range   { 0.1! 5! }
                    parmtag { "script_action" "kwargs['node'].hdaModule().flam3.flam3h_general_utils(kwargs).viewportWireWidth(3.0)" }
                    parmtag { "script_action_help" "[LMB] to reset this parameter to a value of: 3.0" }
                    parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarWhiteSVG.svg" }
                    parmtag { "script_callback" "hou.phm().flam3.flam3h_general_utils(kwargs).viewportWireWidth(), kwargs['parm'].deleteAllKeyframes()" }
                    parmtag { "script_callback_language" "python" }
                }
            }

            groupcollapsible {
                name    "f_prefsf3hdata"
                label   "prefs FLAM3H™ DATA PRIVATE"
                invisibletab
                grouptag { "group_type" "collapsible" }

                parm {
                    name    "icon_custom_7"
                    label   "custom"
                    type    button
                    nolabel
                    joinnext
                    default { "0" }
                    help    "This custom data is used for the well being of some functionalities.\\n\\nNever touch this data unless you are developing additional features\\nthat require changes or debug informations from those options."
                    disablewhen "{ aboutdisable == 1 }"
                    parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarBlueSVG.svg" }
                    parmtag { "script_callback" "" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "private_label"
                    label   "private heading"
                    type    label
                    default { "Never touch this data for the well being of FLAM3H™" }
                    parmtag { "sidefx::look" "heading" }
                }
                groupsimple {
                    name    "f_prefssys"
                    label   "FLAM3H™ system"
                    disablewhentab "{ aboutdisable == 1 }"
                    grouptag { "group_type" "simple" }

                    parm {
                        name    "h_valid"
                        label   "Valid version"
                        type    toggle
                        default { "1" }
                        help    "Is this FLAM3H™ version valid for this Houdini version ?"
                        disablewhen "{ flamefunc == 0 }"
                        parmtag { "script_callback" "" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "empty_prefs_01"
                        label   "empty"
                        type    geometrydata
                        nolabel
                        default { "0" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "doff"
                        label   "FF"
                        type    toggle
                        default { "0" }
                        help    "IS the FF(finalXform) ON/Active or OFF/disabled ?"
                        disablewhen "{ flamefunc == 0 }"
                        parmtag { "script_callback" "" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "rip"
                        label   "RIP"
                        type    toggle
                        default { "0" }
                        help    "Remove invalid points. INF, NAN, ZERO Alpha and out-of-bounds points. It can happen that some points shoot to infinity after being transformed by the algorithm. Set this on when rendering ( especially for a sequence ) to avoid black/failed frames."
                        disablewhen "{ flamefunc == 0 } { outsensor == 1 }"
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "f3c"
                        label   "F3C (flam3 compatibility)"
                        type    toggle
                        default { "1" }
                        help    "F3C\\n\\nThe behavior of the Cos, Cosh, Cot, Coth, Csc, Csch, Sec, Sech, Sin, Sinh, Tan and Tanh variations are different in flam3/Apophysis versus Chaotica.\\n\\nThe behavior of the Cross and Curve variations are also different in Flam3/Apophysis versus Chaotica.\\n\\nChecked: use the Apophysis behavior.\\n\\nUnchecked: use the Chaotica behavior.\\n\\nNOTE:\\nThis has the important property to update and refresh all the Presets menus data\\n(CP, IN and OUT presets menus)"
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "tag"
                        label   "TAG"
                        type    toggle
                        default { "0" }
                        help    "Enable Display TAG infos"
                        disablewhen "{ flamefunc == 0 }"
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "outsensor"
                        label   "SENSOR"
                        type    toggle
                        default { "0" }
                        help    "OFF by default.\\n\\nIs the camera sensor OFF or ON ?"
                        disablewhen "{ flamefunc == 0 }"
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "vptype_mem"
                        label   "MEM display"
                        type    integer
                        default { "0" }
                        help    "What point viewport display type is being used.\\nFor points it will be 0(Zero) and 1(one) for pixels.\\n\\nIt used to as a memory value to revert back to it\\nwhen the user try to change this value from the preferences viewport tab while being in a LOP context."
                        range   { 0 10 }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "vpptsize_mem"
                        label   "MEM size"
                        type    float
                        default { "1" }
                        help    "If display type is set to Points, this will set the size of those points in the viewport.\\n\\nAt the moment of this writing (up to H21),\\nIt is suggested to go to the Houdini: Edit->Preferences->3Dviewport and set the Renderer to OpenGL as it provide a better points visualization in the viewport when millions of them are displayed and/or their viewport point size is smaller than 1(one).\\n\\nChanging the viewer renderer will require a restart of Houdini.\\n\\nIt used to as a memory value to revert back to it\\nwhen the user try to change this value from the preferences viewport tab while being in a LOP context."
                        range   { 0.1! 2 }
                        parmtag { "script_action_help" "Reset this parameter to a value of: 1.0" }
                        parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarWhiteSVG.svg" }
                        parmtag { "script_callback" "" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "vpww_mem"
                        label   "MEM wire width"
                        type    float
                        default { "3" }
                        help    "When the SYS -> \"xforms handles VIZ\" is ON, this parameter will set the wire curves thickness for the viewport display. A value of 3.0 is generally good.\\n\\nIt used to as a memory value to revert back to it\\nwhen the user try to change this value from the preferences viewport tab while being in a LOP context."
                        range   { 0.1! 5! }
                        parmtag { "script_action_help" "Reset this parameter to a value of: 3.0" }
                        parmtag { "script_action_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarWhiteSVG.svg" }
                        parmtag { "script_callback" "" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "icon_custom_6"
                        label   "custom"
                        type    button
                        nolabel
                        joinnext
                        default { "0" }
                        help    "Spacing the Xaos weight will turn this toggle ON and OFF"
                        disablewhen "{ aboutdisable == 1 }"
                        parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarBlueSVG.svg" }
                        parmtag { "script_callback" "" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "empty_prefs_02"
                        label   "empty"
                        type    geometrydata
                        nolabel
                        default { "0" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "xaosdiv"
                        label   "auto space xaos weights"
                        type    toggle
                        default { "1" }
                        help    "Will space the xaos weights for easy read and count ( ON/OFF )."
                        disablewhen "{ autoxaos == 0 }"
                        parmtag { "script_callback" "" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "icon_custom_5"
                        label   "custom"
                        type    button
                        invisible
                        nolabel
                        joinnext
                        default { "0" }
                        help    "This data is for the copy/paste undos and xaos undos."
                        disablewhen "{ aboutdisable == 1 }"
                        parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarBlueSVG.svg" }
                        parmtag { "script_callback" "" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "empty_prefs_03"
                        label   "empty"
                        type    geometrydata
                        invisible
                        nolabel
                        default { "0" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "autopath"
                        label   "auto correct output paths"
                        type    toggle
                        invisible
                        default { "1" }
                        help    "ON by default.\\nThis is a simple autocorrection of the output filenames for the CP and OUT tabs.\\n\\nAs of now this toggle it set to always be ON/Active and it should probably be removed from FLAM3H™ at some point.\\nIt is kept around until I d'nt find the time to make the necessary correction inside the python module.\\n\\nThis toggle will need to be removed at some point."
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "icon_custom_4"
                        label   "custom"
                        type    button
                        nolabel
                        joinnext
                        default { "0" }
                        help    "This data is to keep track of the xform handles VIZ modes"
                        disablewhen "{ aboutdisable == 1 }"
                        parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarBlueSVG.svg" }
                        parmtag { "script_callback" "" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "empty_prefs_04"
                        label   "empty"
                        type    geometrydata
                        nolabel
                        default { "0" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "vizhandles"
                        label   "viewport xforms VIZ"
                        type    toggle
                        default { "0" }
                        help    "OFF by default.\\nWhen switched ON it will display the xforms handles in the viewport.\\n\\nThese handles are not editable, but only for visualization purpose.\\nThey will be helpful to better grasp how the affine values (PRE and POST affine) are acting over each iterator of the fractal Flame.\\n\\nWARNING:\\nTurn this OFF when rendering."
                        parmtag { "script_callback" "" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "vizhandles_solo"
                        label   "viewport xforms VIZ (solo)"
                        type    toggle
                        default { "0" }
                        help    "OFF by default.\\nWhen switched ON it will display the xforms handles in the viewport.\\n\\nThese handles are not editable, but only for visualization purpose.\\nThey will be helpful to better grasp how the affine values (PRE and POST affine) are acting over each iterator of the fractal Flame.\\n\\nWARNING:\\nTurn this OFF when rendering."
                        disablewhen "{ vizhandles == 0 }"
                        parmtag { "script_callback" "" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "vizhandles_solo_mpidx"
                        label   "mpidx"
                        type    integer
                        default { "0" }
                        help    "The multi parameter index of the iterator being in xform handle SOLO mode.\\n\\nWhen no iterator is in SOLO mode this value will be 0(Zero)\\notherwise it will be the multi parameter index number of the iterator being in SOLO mode."
                        disablewhen "{ vizhandles == 0 } { vizhandles_solo == 0 }"
                        range   { 0! 9 }
                        parmtag { "autoscope" "0000000000000000" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "vizhandlesff_solo"
                        label   "viewport xforms VIZ FF (solo)"
                        type    toggle
                        default { "0" }
                        help    "OFF by default.\\nWhen switched ON it will display the xforms handles for the FF in the viewport.\\n\\nThis handle is not editable, but only for visualization purpose.\\nIt will be helpful to better grasp how the affine values (PRE and POST affine) are acting over the iterator FF of the fractal Flame.\\n\\nWARNING:\\nTurn this OFF when rendering."
                        disablewhen "{ flamefunc == 0 }"
                        parmtag { "script_callback" "" }
                        parmtag { "script_callback_language" "python" }
                    }
                }

                groupcollapsible {
                    name    "f_prefscustom"
                    label   "FLAM3H™ custom"
                    disablewhentab "{ aboutdisable == 1 }"
                    grouptag { "group_type" "collapsible" }

                    parm {
                        name    "flam3custom_msg"
                        label   "flam3custom_msg"
                        type    label
                        default { "The following parameters\nare part of FLAM3H™ custom memory data.\n\nThey are used to keep track, restore and compare data\nfor the well being of some algorithm core functionalities." }
                        parmtag { "sidefx::look" "block" }
                    }
                    parm {
                        name    "icon_custom_2"
                        label   "custom"
                        type    button
                        nolabel
                        joinnext
                        default { "0" }
                        help    "This data is for the copy/paste undos and xaos undos."
                        disablewhen "{ aboutdisable == 1 }"
                        parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarBlueSVG.svg" }
                        parmtag { "script_callback" "" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "empty_prefs_05"
                        label   "empty"
                        type    geometrydata
                        nolabel
                        default { "0" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "flam3h_data_mpidx"
                        label   "mpidx"
                        type    integer
                        default { "0" }
                        help    "When this value is 0(Zero) mean no iterators has been marked for copying.\\nWhen this value is above 0(Zero) it will be the multi paramter index of the marked iterator.\\nWhen this value is -1 will signify that a marked iterator has been removed/deleted."
                        range   { -1! 0 }
                        parmtag { "autoscope" "0000000000000000" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "flam3h_data_mpmem"
                        label   "flam3h_data_mpmem"
                        type    label
                        default { "" }
                        parmtag { "sidefx::look" "block" }
                    }
                    parm {
                        name    "flam3h_data_xaos"
                        label   "flam3h_data_xaos"
                        type    label
                        default { "" }
                        parmtag { "sidefx::look" "block" }
                    }
                    parm {
                        name    "empty_prefs_06"
                        label   "empty"
                        type    geometrydata
                        nolabel
                        default { "0" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "icon_custom_3"
                        label   "custom"
                        type    button
                        nolabel
                        joinnext
                        default { "0" }
                        help    "Color correction curves data"
                        disablewhen "{ aboutdisable == 1 }"
                        parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarBlueSVG.svg" }
                        parmtag { "script_callback" "" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "empty_prefs_07"
                        label   "empty"
                        type    geometrydata
                        nolabel
                        default { "0" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "flam3curves_msg"
                        label   "flam3curves_msg"
                        type    label
                        default { "The following data represent\ncolor correction curves coming from Fractorium.\n\nIf a flame you are loading was not authored in Fractorium\ndefault values will be used instead." }
                        parmtag { "sidefx::look" "block" }
                    }
                    parm {
                        name    "outcurves"
                        label   "curves"
                        type    label
                        default { "" }
                        parmtag { "sidefx::look" "block" }
                    }
                    parm {
                        name    "outcurveoverall"
                        label   "overall"
                        type    label
                        default { "" }
                        parmtag { "sidefx::look" "block" }
                    }
                    parm {
                        name    "outcurvered"
                        label   "red"
                        type    label
                        default { "" }
                        parmtag { "sidefx::look" "block" }
                    }
                    parm {
                        name    "outcurvegreen"
                        label   "green"
                        type    label
                        default { "" }
                        parmtag { "sidefx::look" "block" }
                    }
                    parm {
                        name    "outcurveblue"
                        label   "blue"
                        type    label
                        default { "" }
                        parmtag { "sidefx::look" "block" }
                    }
                    parm {
                        name    "flam3custom_heading_div_4"
                        label   "flam3custom_heading"
                        type    label
                        default { "" }
                        parmtag { "sidefx::look" "heading" }
                    }
                }

                groupsimple {
                    name    "f_prmtemp"
                    label   "FLAM3H™ temp parms"
                    disablewhentab "{ aboutdisable == 1 }"
                    grouptag { "group_type" "simple" }

                    parm {
                        name    "icon_custom_8"
                        label   "custom"
                        type    button
                        nolabel
                        joinnext
                        default { "0" }
                        help    "Temp parameters"
                        disablewhen "{ aboutdisable == 1 }"
                        parmtag { "button_icon" "opdef:/alexnardini::Sop/FLAM3H?icon_optionStarBlueSVG.svg" }
                        parmtag { "script_callback" "" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "empty_prefs_08"
                        label   "empty"
                        type    geometrydata
                        nolabel
                        default { "0" }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "flam3tmpprm_msg"
                        label   "flam3tmpprm_msg"
                        type    label
                        default { "The following parameters are used to temporarily\nstore data to then be copied somewhere else.\n\nThey are used by the swap PRE or POST variation's order\ninside the iterators and FF.\n\nIterator's PRE and FF's POST variations\nare both two so we have two temp integers\nfor the variation name indexes\nand two temp floats for their weights." }
                        parmtag { "sidefx::look" "block" }
                    }
                    parm {
                        name    "sepparm"
                        label   "Spacer"
                        type    separator
                        default { "" }
                        parmtag { "sidefx::layout_height" "large" }
                        parmtag { "sidefx::look" "blank" }
                    }
                    parm {
                        name    "tmp_int_0"
                        label   "Temp int 0"
                        type    integer
                        default { "0" }
                        range   { 0 10 }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "tmp_int_1"
                        label   "Temp int 1"
                        type    integer
                        default { "0" }
                        range   { 0 10 }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "tmp_float_0"
                        label   "Temp float 0"
                        type    float
                        default { "0" }
                        range   { 0 10 }
                        parmtag { "script_callback_language" "python" }
                    }
                    parm {
                        name    "tmp_float_1"
                        label   "Temp float 1"
                        type    float
                        default { "0" }
                        range   { 0 10 }
                        parmtag { "script_callback_language" "python" }
                    }
                }

            }

        }

    }

