                    nolabel
                    joinnext
                    default { "0" }
                    parmtag { "script_action" "kwargs['node'].hdaModule().flam3usd.flam3husd_about_utils(kwargs).flam3husd_web_run('web')" }
                    parmtag { "script_action_help" "Open a web browser to the FLAM3H website." }
                    parmtag { "script_action_icon" "opdef:/alexnardini::Lop/FLAM3HUSD?iconSVGB.svg" }
