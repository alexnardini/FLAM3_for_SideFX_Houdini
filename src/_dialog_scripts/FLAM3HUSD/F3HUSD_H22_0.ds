                    type    geometrydata
                    nolabel
                    default { "0" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "icon_f3h_links"
                    label   "FLAM3H links"
                    type    button
                    nolabel
                    joinnext
                    default { "0" }
                    help    "List of web links about FLAM3H™"
                    disablewhen "{ aboutdisable == 1 }"
                    parmtag { "button_icon" "opdef:/alexnardini::Lop/FLAM3HUSD?icon_optionStarBlueSVG.svg" }
                    parmtag { "script_callback" "" }
                    parmtag { "script_callback_language" "python" }
